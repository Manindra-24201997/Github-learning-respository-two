                       <td style="font-weight:bold;">Illumination :</td>
                       <td>{!item.bb.Illumination__c}</td>
                     
                     </tr>
                   
                    <tr>
                       <td style="font-weight:bold;">Latitude :</td>
                       <td>{!item.bb.Latitude__c}</td>
                     
                     </tr>
                     
                     <tr>
                       <td style="font-weight:bold;">Longitude :</td>
                       <td>{!item.bb.Longitude__c}</td>
                     
                     </tr>
                   
                   </table>
                 
     
    
            </apex:column>
     
          <apex:column style="page-break-after: always;"  width="15%">
           
     
               
          
          </apex:column>
          
     
           <apex:column style="page-break-after: always;page-break-inside: avoid;"  width="25%">
           
     
               <apex:outputfield value="{!item.bb.Photo_1_New__c}" style="height:10px;width:10px;" rendered="{!Not(IsBlank(item.bb.Attachment_ID__c ))}"></apex:outputfield>
          
          </apex:column><br/>
          
      
     
      </tr>
      
      
      
      </table><br/><br/><br/><br/><br/><br/><br/><br/><br/>
     
         </div><hr style="margin-bottom:-5px;margin-top:-4px;noshade;"/>
         </apex:dataTable>
         
         -->
         
         
         
         </div>
         </apex:repeat>
         
         </apex:repeat>
      
       
       
     
     
     
     
 
 
       </body>
       
   </html>
   

   
</apex:page>