<apex:page controller="BB_Binder_Report_Pdf_Class" readonly="True" renderAs="pdf" standardStylesheets="false" showHeader="false" applyHtmlTag="false">
 
 
 
 <html>
        <head>
          <style type="text/css">
            @page{
                size:portrait;
                margin : .7in .3in 1.5in .5in;
                counter-increment: pages;
                
                @top-Left{
                content:element(header) ;
                Background-repeat:no-repeat;
                font-size:20px;
                font-Weight:bold;
                
                
     
                   }   
                
                @bottom-center{
                   content : element(footer); 
                    height:50px;         
                    }
                    
                @bottom-right 
               {
                  content: "Page " counter(page);
                    font-family: sans-serif !important;
                  font-size:8pt;
                } 
                
                
                
                    
               
                    
                 @bottom-left-corner
                   {
                       content: "<apex:outputText value="{0,date,MM'/'dd'/'yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
                        background-repeat: no-repeat;
                       font-size:10pt;
                         font-family: sans-serif !important;
                       padding-left: 20px;
                       padding-top:20px;
                  }   
            
                }
                
                
                div.header{
                    position : running(header);
                    line-height:17px;
                }
               
               
               @page { 
                    margin-left: 5mm;
                    margin-right: 4mm;
                    margin-top:5cm;
                    margin-bottom:20mm;
                    page-break-inside: avoid;
                    
                } 
                body { line-height:90% !important; } 


               
            </style> 
        
        
        
        
         
        
        </head>
        
         <body> 
     
          
       
       
        <apex:repeat value="{!CDWrapper}" var="cdw">
        
       
         <apex:repeat value="{!cdw.CNWrapper}" var="cnw" >
         
           <div style="page-break-after: always;">
         
         <div class="header" >
         
         
         
           
               <table border="0" cellspacing="0" cellpadding="0" width="100%" id="table1">
                  <tr>
                    <td rowspan="5" width="60"><Br/>
                       <apex:image id="JS_logo" value="{!$Resource.JS_Logo}" rendered="{!imageNotFound == True}" />
                       <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}" />
                       
                    </td>
                    <td></td>
                    <td></td>
                    <td>&nbsp;&nbsp;</td>
                    <td align= "right" style="font-family: sans-serif !important;font-weight:bold;font-size:18px">
                     &nbsp;BB Binder Report
                   </td>
                 </tr>
              </table> <br/>
         
        
         
         
            <div style="width:100%;font-weight: bolder;width:100%;  font-family: sans-serif !important;">
              
                <b> <apex:outputText value="{!cdw.strClientDist}"   style="font-size:18px;font-weight:bold;  font-family: sans-serif !important;"/> </b> 
           
              </div> <br/>
              
              <hr style="margin-bottom:-5px;margin-top:-4px;noshade;"/><br/> 
              
              <div style="width:100%;font-weight: bolder;width:100%;font-family: sans-serif !important;">
                 <b> <apex:outputText value="{!cnw.strClientName}"   style="font-size:14.5px;font-weight:bold;"/> </b> , <b> <apex:outputText value="{!cnw.strClientcode}"   style="font-size:14.5px;font-weight:bold;"/> </b>
               </div>    <br/>   
              <hr style="margin-bottom:-5px;margin-top:-4px;noshade;"/> 
               
             
             </div> 
         
        
        
        <apex:repeat value="{!cnw.BWrapper}" var="item">
        
          <div style="page-break-inside: avoid;  font-family: sans-serif !important;"> 
            
           <b> <apex:outputText value="{!item.bb.Title__c}"   style="font-size:14px;font-weight:bold;page-break-inside: avoid;"/> </b> 
           <br/>  <br/>        
              <hr style="margin-bottom:-5px;margin-top:-4px;noshade;"/>  <br/>  
           
             
             
               <table style="page-break-inside: avoid;">
               
                  <tr style="vertical-align:top;" width="50%" >   
                    
                    <td style="font-size:13px" >
                 <!--  <apex:outputText value="Title :" style="font-weight:bold;font-size:14px"> </apex:outputText> {!item.bb.Title__c} <br/>
                   
                   <apex:outputText value="BB#:" style="font-weight:bold;font-size:14px"> </apex:outputText> {!item.bb.name}<br/>
                    
                    
                  <apex:outputText value="BB#:" style="font-weight:bold;font-size:14px"> </apex:outputText>  Client :{!item.bb.Client_Name__r.name}<br/>-->
                    
                  <apex:outputText value="Vendor :" style="font-weight:bold;font-size:14px"> </apex:outputText> {!item.bb.BB_Vendor__r.name}<br/><br/>
                    
                <apex:outputText value="PMT :" style="font-weight:bold;font-size:14px"> </apex:outputText>    {!item.bb.PMT__c}<br/><br/>
                    
                 <apex:outputText value="Expiration Date :" style="font-weight:bold;font-size:14px"> </apex:outputText>  
                        <apex:outputText value="{0,date,MM'/'dd'/'yy}"  rendered="{!if(item.bb.Expiration_Date__c !=null,true,false)}">
                        <apex:param value="{!if(item.bb.Expiration_Date__c !=null,item.bb.Expiration_Date__c,'-')}"/> </apex:outputText>
                        <apex:outputText value=" " rendered="{!if(item.bb.Expiration_Date__c == null,true,false)}" ></apex:outputText> 
                       <br/><br/>
                         
                   
                     
                    
                <apex:outputText value="Location :" style="font-weight:bold;font-size:14px"> </apex:outputText>    {!item.bb.Location__c}<br/> <br/>
                    
                <apex:outputText value="Illumination :" style="font-weight:bold;font-size:14px"> </apex:outputText>    <apex:outputField value="{!item.bb.Illumination__c}"/>  <br/>  <br/>
                    
                <apex:outputText value="Latitude :" style="font-weight:bold;font-size:14px"> </apex:outputText>    {!item.bb.Latitude__c}<br/>  <br/>
                     
               <apex:outputText value="Longitude :" style="font-weight:bold;font-size:14px"> </apex:outputText>     {!item.bb.Longitude__c}<br/>  <br/>
                       
                    
                     
                   </td>
                   
                   <td width="30%">
                        <apex:image id="theImage" value="/sfc/servlet.shepherd/version/download/{!item.ContentVersionId}"  style="height:170px; width:200px;" alt="Description of image here"/>
                   <br/>
                   </td>
                   
                   
                  </tr>    
                  
               </table><hr style="margin-bottom:-5px;margin-top:-4px;noshade;"/><br/> 
             
             </div> 
             
           </apex:repeat>
        
        
        
        
        
           
