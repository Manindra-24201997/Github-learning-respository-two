                                                                      '</a>'+'</div>';
                                                                      addListener(id, marker,id,contentString);    
                                                                  }
                                                                  
                                                              }
                                                          } else {
                                                              alert(event.message);
                                                          }
                                                      },
                                                      {escape: true}
                                                     ); 
