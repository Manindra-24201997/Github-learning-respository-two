<apex:page standardController="Job__c" extensions="SiteJobRequestFormVfPageExt" sidebar="true" docType="html-5.0" standardStylesheets="true" showHeader="false" applyBodyTag="false" applyHtmlTag="false">
   
    <apex:slds />
    <style>
        
        .pageHeader 
        {
        color:white;
        background-color:#851225;
        height:70px;
        padding-top:23px; 
        position:fixed;
        z-index:999;
        width:100% !important;
        padding-left:22px;
        }
        
        .SectionHeader
        {
        background-color:Grey !important;
        color:white;
        }
        
        .bPageBlock 
        {
        margin: 20px 20px 20px 20px !important;
        }
        
        
        body
        {
        //background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgba(32, 92, 159, 0), rgb(32, 92, 159));
        //background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, #d4d7da, #666) !important;
        background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgb(212, 228, 247), rgb(32, 92, 159));
        //background-image:none !important;
        //background-color:#D7D7D7 !important;
        background-repeat: repeat-x;
        background-position: left top;
        background-attachment: fixed; 
        margin:0px !important;
        }
        
        .customImage{ height: 10px; width: 10px; }
        #rcorners1 
        {
        border-radius:0%;
        border: 1px solid #cccccc;
        padding: 0px; 
        width: 100%;
        height: 0%;
        }
        #pagemessage
        {
        color:blue;
        }
        
        .required:after { content:" *";  color: Red;font:bold;}
        
        .slds table
        {
        height: 50px;
        }
        body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons
        {
        margin-top: -19px; 
        }
        .detailPage .bPageBlock, .editPage .bPageBlock
        {
        border-top-width: 0px;
        }
        
        .slds .slds-text-heading--large
        {
        font-size: 27px;
        }
        
        .pbHeader
        {
        background: white !important;
        }
        
        body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons 
        {
        background: white;
        }
        
        .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
        {
        border:none;
        }
        
        body .bEditBlock .pbBottomButtons, body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons
        {
        border:none;
        }
        
        .slds .slds-checkbox .slds-checkbox--faux 
        {
        width: 25px;
        height: 25px;
        display: inline-block;
        position: relative;
        vertical-align: middle;
        border-width: 2px;
        border-style: solid;
        border-color: lightgrey;
        border-image: initial;
        border-radius: 2px;
        background: white;
        transition: border 0.1s linear, background-color 0.1s linear;
        }
        
     
        
        .bPageBlock .requiredInput .requiredBlock 
        {
        background-color:white;
        position: absolute;
        left: -4px;
        width: 3px;
        top: 1px;
        bottom: 1px;
        }
        
        errorM6, .errorM4, .errorM3, .errorM2, .errorS1 
        {
        border-color: #c00;
        }
        .message 
        {
        background-color: #c00;
        border-style: solid;
        border-width: 0px;
        color: #000;
        padding: 0px 0px 0px 0px;
        margin: 0px 0px;
        }
        .errorM3 .msgIcon, .errorMedium 
        {
        background-image: url(); 
        background-position: 0 0;
        width:0px;
        height: 0px;
        padding-left: 4px;
        }
        .pbBody td
        {
        color:black;
        }
        .message .messageText h4 
        {
        font-weight: bold; 
        display:block;
        color:white;
        }
        
        .messageText br
        {
        display:none !important;
        }
        .messageTable tr
        {
        padding-top:10px !important;
        padding-bottom:10px !important;
        }
       
        
        
        <!----------------------------------- error Mesgg-------------------------------------->
        
        td,th 
        {
        font-size:13px; font-family:Arial;
        }
        input ,select,textarea
        {
        background-color: #EEEEEE;
        }
        
    </style>  
    
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        
        <body>
            
            <!-- REQUIRED SLDS WRAPPER -->
            <div class="slds">
                <br/><br/>
                <apex:form html-novalidate="novalidate">
                   
                    <apex:pageBlock mode="edit">
                        <div align="center">
                            <h1 class="slds-text-heading--label" style="font-size: 1.25rem;padding-top: 26px;"><b> Thank you...! Your order was saved in our database.</b></h1>
                        </div>
                        <br/><br/>
                        <apex:pageBlockButtons location="bottom">
                            <apex:commandButton value="Create New Job" action="{!newJob}" styleClass="slds-button slds-button--brand" style="margin-left:120px;"/>
                        </apex:pageBlockButtons>
                    </apex:pageBlock>   
                    <br/><br/>
                </apex:form>
            </div> 
        </body>
    </html>
</apex:page>