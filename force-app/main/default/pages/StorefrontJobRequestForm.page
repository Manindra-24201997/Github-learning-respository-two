    <script>
    function Hidetext(ele) {
        ele.value = '(xxx)xxx-xxxx';
    }
    
    function validatePhone(CorporatePhone) {
        var num = CorporatePhone;
        if (num.length > 10) {
            //Alert the user that the phone number entered was invalid.
            alert('Please enter a valid phone number');
        } else {
            //Format (xxx)-xxx-xxxx
            CorporatePhone.value = "(" + num.substring(0, 3) + ") " + num.substring(3, 6) + "-" + num.substring(6);
        }
    }
    </script>
    
