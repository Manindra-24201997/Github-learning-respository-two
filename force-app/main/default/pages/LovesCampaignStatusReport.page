<apex:page Controller="LovesCampaignStatusReport" showHeader="false" renderAs="pdf" standardStylesheets="false" applyHtmlTag="false">
  
  <html>
        <head>
          <style type="text/css">
            @page{
                size:landscape;
                margin : .7in .3in 1.5in .5in;
                counter-increment: pages;
                
                @top-Left{
                content:element(header) ;
                Background-repeat:no-repeat;
                font-size:20px;
                font-Weight:bold;
                  font-family: sans-serif !important;
                
     
                   }   
                
                @bottom-center{
                   content : element(footer); 
                    height:50px;         
                    }
                    
                @bottom-right 
               {
                  content: "Page " counter(page);
                    font-family: sans-serif !important;
                  font-size:8pt;
                } 
                
                
                
                    
               
                    
                 @bottom-left-corner
                   {
                       content: "<apex:outputText value="{0,date,MM'/'dd'/'yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
                        background-repeat: no-repeat;
                       font-size:10pt;
                         font-family: sans-serif !important;
                       padding-left: 20px;
                       padding-top:20px;
                  }   
            
                }
                
                
                div.header{
                    position : running(header);
                    line-height:18px;
                }
               
               
               @page { 
                    margin-left: 5mm;
                    margin-right: 4mm;
                    margin-top:5cm;
                    margin-bottom:20mm;
                    page-break-inside: avoid;
                    
                } 
                body { line-height:90% !important; } 


               
            </style> 
        
        
        
         <!--  <style type="text/css">
             @page{
                size:landscape;
                
             @top{
                content:element(header) ;
                Background-repeat:no-repeat;
                font-size:17px;
                font-Weight:bold;
                
                
     
                   }   
                
            @bottom-right
            {
            content: "Page " counter(page);
            font-family:Arial;
            font-size:8pt;
            }
   
            @bottom-left 
            {
            content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>"; 
            background-repeat: no-repeat;
            font-size:8pt;
            font-family:Arial;
            } 
                
                
              }  
            div.header{
                    position : running(header);
                    line-height:18px;
                }
               
            </style>  -->
        
        </head>
        
         <body> 
     
        
         <apex:repeat value="{!CNWrapper}" var="cnw">
          
          <div style="page-break-after: always;" > 
         
         
          <div class="header" style="page-break-after: always;">  
           
               <table border="0" cellspacing="0" cellpadding="0" width="100%" id="table1">
                  <tr>
                    <td rowspan="5" width="60"><Br/>
                       <apex:image id="JS_logo" value="{!$Resource.JS_Logo}" rendered="{!imageNotFound == True}" />
                       <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}" />
                       
                    </td>
                    <td></td>
                    <td></td>
                    <td>&nbsp;&nbsp;</td>
                    <td align= "right" style="font-family: sans-serif !important;font-weight:bold;font-size:18px">
                     &nbsp;Campaign Status Report
                   </td>
                 </tr>
              </table> <br/>
              
          <!-- <div style="page-break-after: always;"> -->
          
               <table width = "100%" style="page-break-inside: avoid;line-height:14px;  font-family: sans-serif !important;">
               <tr>
                 <td style="height:10%;width:20px;">
                   
                     <b><apex:outputLabel value="Job Name" style="font-size:15px;vertical-align:Top !important;"></apex:outputLabel></b>
                  
                 </td>
                                    
                                   
                  <td style="height:10%;width:1px;">
                   
                     <b><apex:outputLabel value="Due Date" style="font-size:15px;vertical-align:Top !important;"></apex:outputLabel></b>
                 
                 </td>
                 
                 <td style="height:10%;width:45px;">
                   
                     <b><apex:outputLabel value="Team" style="font-size:15px;vertical-align:Top !important;"></apex:outputLabel></b>
                  
                 </td>
                 
                 <td style="height:10%;width:90px;">
                   
                     <b><apex:outputLabel value="Schedule" style="font-size:15px;vertical-align:Top !important;"></apex:outputLabel></b>
                  
                 </td>
                 
                     <td style="height:10%;width:100px;">
                      
                     <b><apex:outputLabel value="Specs" style="font-size:15px;vertical-align:Top !important;"></apex:outputLabel></b>
                  
                 </td>
                 
                 
                     <td style="height:10%;width:30px;">
                      
                     <b><apex:outputLabel value="Job Notes" style="font-size:15px;vertical-align:Top !important;"></apex:outputLabel></b>
                  
                 </td>
                </tr>
               </table><br/>
                <hr style="margin-bottom:-5px;margin-top:-4px;noshade;"/><br/>
               
                      
             <!-- <div style="width:100%;font-weight: bolder;width:100%;background-color:#C9C7C9;">
              
                <b> <apex:outputText value="{!cnw.strCampaignName}"    style="font-size:18px;font-weight:bold;font-color:#0000FF;"/> </b> 
           
              </div> -->
              
              <table width="100%" style = "background-color:#C9C7C9;margin-bottom:-10px;page-break-inside: avoid;  font-family: sans-serif !important;">
                        <tr style="page-break-inside: avoid;">
                            <td width = "20%" style="page-break-inside: avoid;">
                                <b> <apex:outputText value="{!cnw.strCampaignName}" style="font-size:18px;font-weight:bold;font-color:#0000FF;"/>  </b>
                            </td>
                        </tr>
                    </table>
              
              
              <br/><br/>    
              
             </div>   
           
             <apex:repeat value="{!cnw.jWrapper}"  var="jw"  >       
              
                                 
               <div style="page-break-inside: avoid;">
                 
               
               <table width="100%" style="margin-bottom:-10px;font-family:sans-serif !important;">
                <tr style="vertical-align:top;">
                
                 <td width = "11%" style="vertical-align:top;">
                   <apex:outputText value="{!jw.job.name}" style="font-size:14px;font-family: sans-serif !important;"/><apex:outputText value="({!jw.job.Job_Auto_Number__c})" style="font-size:14px;"/><br/>
                   <apex:outputText value="{!jw.job.Campaign__r.name}" style="font-size:14px;font-family: sans-serif !important;"/>
                 </td>
                
                <td width = "9%" style="vertical-align:top;padding-top: 2px;">
                   <apex:outputText style="width:100%;float:left;font-size:14px;font-family: sans-serif !important;padding-top: 2px;" value="{0,date,MM'/'dd'/'yy}"  rendered="{!if(jw.job.Due_Date__c !=null,true,false)}">
                    <apex:param value="{!if(jw.job.Due_Date__c !=null,jw.job.Due_Date__c,'-')}"/> </apex:outputText>
                    <apex:outputText style="width:100%;float:right; align:center;padding-top: 2px;" value=" " rendered="{!if(jw.job.Due_Date__c == null,true,false)}" ></apex:outputText> 
                  
                 
                 </td>
                 <td width = "10%" style="vertical-align:top;">
                   <apex:repeat value="{!jw.jobTeams}" var="jobTeams">
             
                   <apex:outputtext value="{!jobTeams}"    style="font-size:14px;height:22px;font-family: sans-serif !important;"/><br/>
             
                  </apex:repeat>
                 
                 </td>
                 <td width = "18%" style="vertical-align:top;">
                   <apex:repeat value="{!jw.jobStasks}" var="jobStasks">
             
                   <apex:outputtext value="{!jobStasks.Name}  : "    style="font-size:14px;height:22px;font-family: sans-serif !important;"/> <br/>
                   
                   <apex:outputText style="width:100%;float:left;font-size:14px;" value="{0,date,MM'/'dd'/'yy}"  rendered="{!if(jobStasks.Revised_Due_Date__c !=null,true,false)}">
                    <apex:param value="{!if(jobStasks.Revised_Due_Date__c !=null,jobStasks.Revised_Due_Date__c,'-')}"/> </apex:outputText> <br/>
                    <apex:outputText style="width:100%;float:right; align:center;" value=" " rendered="{!if(jobStasks.Revised_Due_Date__c == null,true,false)}" ></apex:outputText>
                   
                   
                  </apex:repeat>
                 
                 </td>
                 <td width = "18%" style="vertical-align:top;">
                   <apex:repeat value="{!jw.jobSpecs}" var="jobSpecs">
                   
                   <div style="width:100%;float:left;" >
                   <apex:outputtext value="{!jobSpecs.Name}  : "    style="font-size:14px;height:22px;font-family: sans-serif !important;" /><br/>
                   
                   <apex:outputtext value="{!jobSpecs.Description__c}"  style="font-size:14px;font-family: sans-serif !important;"/><br/><!-- value="{!jobSpecs.Description__c}"-->
                   </div>
                   
                   
                  </apex:repeat>
                  </td>
                  
                  <td width = "12%" style="vertical-align:top;">
                   <div style="width:100%;float:left;font-size:14px;font-family:sans-serif !important;" align = "left">
                    <apex:outputField value="{!jw.job.Creative_Overview__c}" style="font-size:14px;font-family:sans-serif !important;"/>
                   </div>
             
                 
                  </td>
                  <hr style="margin-top:20px;"/>
                </tr>    
                  
               </table>
             
             </div>  
              
            </apex:repeat>   
           
        </div>
      </apex:repeat>
       
    </body>
        
</html>
  
</apex:page>