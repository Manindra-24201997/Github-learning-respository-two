<apex:page controller="BillboardRepairFormExt" sidebar="true" docType="html-5.0" applyBodyTag="False" standardStylesheets="false" applyHtmlTag="False" showHeader="False">
    <style>
        .sfdc_richtext img {
        border: 0;
        height: 30%;
        width: 30%;
        }
        
        .button2 {
        background-color: #FFD700;
        font-weight: bold;
        color: Black;
        }
        
        #ProductsTable img {
        opacity: 50%;
        width: 20% !Important;
        }
        
        .customImage{ height: 10px; width: 10px; }
        #rcorners1 {
        border-radius:0%;
        border: 1px solid #cccccc;
        padding: 0px; 
        width: 100%;
        height: 0%;
        }
        #pagemessage
        {
        color:blue;
        }
        .required:after { content:" *";  color: Red;font:bold;}
        
        html,html body
        {
        overflow: auto;
        -webkit-overflow-scrolling:auto;
        }
        body
        {
        position:absolute;left:0;right:0;top:0;bottom:0;
        margin:0;
        }
        
        .slds .slds-table .slds-truncate 
        {
        min-width: 52px !important;
        max-width: 125px !important;
        }
        
        .slds-checkbox .slds-checkbox--faux
        {
        border: 2px solid lightslategrey !important;
        }  
        
        
    </style>
    
    <script>
    function myFunction() {
        var x = document.getElementById("myDIV");
        var y=document.getElementById("waitmsg");
        x.style.opacity= 0.3;
        y.style.display = "block";
    }
    </script>
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0122, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        
        <body>
            <div id="waitmsg" style="display:none;position:absolute;top:50%;left:50%">
                <center>
                    <h2>
                        <img src="/img/loading.gif"/>  Please wait...
                    </h2>
                </center>
            </div>
            
            <div class="slds" id="myDIV">
                <apex:form enctype="multipart/form-data" html-novalidate="novalidate" id="CusOrderID">
                    
                    <apex:image value="{!$Resource.LovesHeaderLogo}" width="250" height="250" style="margin-left:2%;"/>
                    <apex:commandButton value="Place Order" action="{!save}" styleClass="slds-button slds-button--brand"  onclick="myFunction()" style="float:right;margin-right:2.75%;margin-top:1.5%;"/>
                    <apex:commandButton value="Back" action="{!back}" styleClass="slds-button slds-button--neutral" style="float:right;margin-right:1%;margin-top:1.5%;"/>
                    
                    <br/>
                    <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" style="width:94%;margin-left:2%;">
                        <apex:pageMessages />
                    </div>
                    <br/>
                    <div style="background-color:#e2e4e6;width:95%;margin-left:2%;">
                        <h3 class="slds-section-title"><b>&nbsp;Billboard/Dot Service Request Form</b></h3>
                    </div>
                    
                    <br/>
                    
                    
                    <div class="slds-grid slds-wrap" style="width:95%;margin-left:2%;" >
                        <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                            
                            <div class="slds-grid slds-wrap">
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b>Location</b></label>
                                        <div class="slds-form-element__control">
                                            <apex:selectList id="BBLName" value="{!BBLName}" size="1" styleClass="slds-select slds-m-right--medium">
                                                <apex:selectOptions value="{!BBLocation}"></apex:selectOptions>
                                            </apex:selectList>
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b>Sign type</b></label>
                                        <div class="slds-form-element__control">
                                            <apex:selectList value="{!BillboardSigntypeList }" id="selectBSignTypeList" multiselect="true" size="2" styleClass="slds-select slds-m-right--medium">
                                                <apex:selectoptions value="{!BillboardSigntype}"></apex:selectoptions>
                                            </apex:selectList>
                                        </div>
                                    </div>
                                </aside>
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b>Billboard</b></label>
                                        <div class="slds-form-element__control">
                                            <apex:selectList id="BBList" value="{!BBList}" size="1" styleClass="slds-select slds-m-right--medium">
                                                <apex:selectOptions value="{!BillboardList}"></apex:selectOptions>
                                            </apex:selectList>
                                        </div>
                                    </div>
                                </aside>
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b>File Storage</b></label>
                                        <div class="slds-form-element__control">
                                            <apex:inputfile value="{!myfile.body}" filename="{!myfile.Name}" styleClass="slds-input"/>
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b>Service Issues</b></label>
                                        <div class="slds-form-element__control">
                                        </div>
                                    </div>
                                </aside>
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label">
                                            <b><apex:outputText value="Select the below options that apply to the signage issues you are having." style="color:red;" /></b>
                                        </label>
                                    </div>
                                </aside>
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <div class="slds-form-element__control">
                                            <apex:selectList value="{!BillboardServiceIssuesList }" id="selectBserviceList" multiselect="true" size="6" styleClass="slds-select slds-m-right--medium">
                                                <apex:selectoptions value="{!BillboardServiceIssues}"></apex:selectoptions>
                                            </apex:selectList>
                                        </div>
                                    </div>
                                </aside>
                                
                                <div class="slds-p-horizontal--small slds-size--1-of-1 slds-medium-size--6-of-6 slds-large-size--12-of-12">
                                    
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                            <apex:outputText value="Currently Reads" />
                                            <div class="slds-form-element__control">
                                                <apex:inputText value="{!BillboardReads}" styleClass="slds-input"/>
                                            </div>
                                        </div>
                                    </aside>
                                    
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                            <apex:outputText value="Should Read " />
                                            <div class="slds-form-element__control">
                                                <apex:inputText value="{!Billboardshouldread}" styleClass="slds-input" />
                                            </div>
                                        </div>
                                    </aside>
                                    
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                            <apex:outputText value="Lighting" />
                                            <div class="slds-form-element__control">
                                                <apex:outputLabel value="If you are experiencing a lighting failure.select below options for each light. " />
                                            </div>
                                        </div>
                                    </aside>
                                    
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                            
                                            <div class="slds-form-element__control">
                                                <apex:selectList value="{!BillboardLightList}" id="selectBLightList" multiselect="true" size="4" styleClass="slds-select slds-m-right--medium">
                                                    <apex:selectoptions value="{!BillboardLight}"></apex:selectoptions>
                                                </apex:selectList>        
                                            </div>
                                        </div>
                                    </aside>
                                    
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                            <apex:outputLabel value="What time(s) are the lights being reported out " />
                                            <div class="slds-form-element__control">
                                                <apex:inputText value="{!Billboardlightout}" styleClass="slds-input"/>
                                            </div>
                                            <div class="slds-form-element__control">
                                                <apex:outputLabel value="(a.m./p.m.) " />
                                            </div>
                                        </div>
                                    </aside>
                                    
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                            <apex:outputLabel value="Notes " />
                                            <div class="slds-form-element__control">
                                                <apex:inputText value="{!BillboardNotes}" styleClass="slds-input"/>
                                            </div>
                                            
                                        </div>
                                    </aside>
                                    <apex:commandButton value="Place Order" action="{!save}" styleClass="slds-button slds-button--brand"  onclick="myFunction()" style="float:right;margin-right:2.75%;margin-top:1.5%;"/>
                                    <apex:commandButton value="Back" action="{!back}" styleClass="slds-button slds-button--neutral" style="float:right;margin-right:1%;margin-top:1.5%;"/>
                                    <br/><br/>
                                </div>
                            </div>
                        </main>
                    </div>
                </apex:form>
            </div>
        </body>
    </html>
    
</apex:page>