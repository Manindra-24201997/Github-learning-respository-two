<apex:page controller="VFpagesDeletionExt"  sidebar="false">
    
    <apex:form >
        <apex:pageBlock id="pb">
            <apex:pageBlockButtons >
                <apex:commandButton value="Delete" action="{!deletepages}" reRender="pb" />
            </apex:pageBlockButtons>
            <apex:pageMessages />
            <apex:pageBlockTable value="{!pages}" var="p" columns="5" Id="pb1">
                <apex:column headerValue="select">
                    <apex:inputCheckbox value="{!p.check}"/>
                </apex:column>
                <apex:column value="{!p.pag.Name}"/>
            </apex:pageBlockTable>
        </apex:pageBlock>
    </apex:form>
    
    
    
</apex:page>