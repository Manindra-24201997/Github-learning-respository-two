    <script>
    function getIEFileSize(file){
        var myFSO = new ActiveXObject("Scripting.FileSystemObject"),
            filepath = file.value,
            thefile = myFSO.getFile(filepath);
        return thefile.size;
    }
    function checkFileSize()
    {
        showSpinner();
        var goodSize = true;
        $('input[type=file]').each(function()
                                   {
                                       if(typeof this.files[0] !== 'undefined')
                                       {
                                           var file = this.files[0],
                                               size = typeof ActiveXObject !== 'undefined' ?
                                               getIEFileSize(file)
                                           :
                                           file.fileSize || file.size;
                                           
                                           goodSize = 26000000 > size;
                                           //alert(size);
                                           if(!goodSize)
                                           {
                                               alert(this.files[0].name +' is too large - please choose a file that is 25Mb or less');
                                           }
                                           else
                                           {
                                               if (2000000 < size)
                                               {
                                                   goodSize=confirm('The file size is ' + size + 
                                                                    ' bytes - this may take some time. Are you sure you wish to continue');
                                               }
                                           }
                                           return goodSize;
                                       }
                                   });
        return goodSize;
    }
    function showSpinner()
    {
        document.getElementById('opaque').style.display='block';
        var popUp = document.getElementById('spinner');
        popUp.style.display = 'block';
    } 
    function filechange(){
        if(!document.getElementsByClassName('jobname')[0].value){
            window.alert('You must enter a '+document.getElementsByClassName('joblabel')[0].textContent); 
            return false;}
        
        if(!document.getElementsByClassName('client')[0].value){
            window.alert('You must enter a '+document.getElementsByClassName('clientlabel')[0].textContent); 
            return false;}
        
        /*  if(!document.getElementsByClassName('sectionattach')[0].value){
           alert('You must enter a '+document.getElementsByClassName('attachlabel')[0].textContent); 
            return false;}*/
        
        // Below commented for media and aschedule template
        /* if(!document.getElementsByClassName('mediatype')[0].value){
           window.alert('You must select a '+document.getElementsByClassName('medialabel')[0].textContent); 
        return false;}
        if(!document.getElementsByClassName('scTemp')[0].value){
           window.alert('You must select a '+document.getElementsByClassName('stemplabel')[0].textContent); 
        return false;}
        
         if(!document.getElementsByClassName('creativeTemp')[0].value){           
           window.alert('You must select a Creative Brief template'); 
        return false;}*/
    }
    
    </script>
    
