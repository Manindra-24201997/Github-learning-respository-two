<!-- This page is used to display Quote Report. -->
<apex:page standardController="Vendor_Quote__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="PrintQuoteExtension" renderAs="pdf">
    <head>
    <style type="text/css">

        .rightalign
        {
        text-align:right;
        }

        .leftalign
        {
        text-align:left;
        }

        .centeralign
        {
        text-align:center;
        }

        div.tab
        {
        width:100%;
        border:solid black;
        }

        @page
        {
            /* Landscape orientation */
            size:landscape;

            /* Put page numbers in the bottom right corner of each
            page in the pdf document. */
        
            @bottom-right
            {
            content: "Page " counter(page);
            font-family: sans-serif !important;
            font-size:8pt;
            }
   
            @bottom-left 
            {
            content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
            background-repeat: no-repeat;
            font-size:8pt;
            font-family: sans-serif !important;
            } 
        }

        body 
        {
        font-family: sans-serif !important;
        font-size:9pt;
        }
  
        th
        {
        font-size:13pt
        font-style:bold;
        font-family: sans-serif !important;
        }

        td
        {
        font-size:11pt;
        font-family: sans-serif !important;
        }
  
        div.footer
        {
        position : running(footer) ;
        }

    </style>
    </head>

    <body>
        <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
        <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>

        <div style="float:right;padding-right:15px;font-size:15pt; font-family: sans-serif !important;font-weight:bold;">
        Quote Report
        </div>
        <br/><br/>

        <table width="100%">
          <tr width="100%">
                <td align="left">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <tr width="100%">
                <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width="100%">
                                <b> <apex:outputText value="DETAILS" style="font-size:11pt;font-weight:bold;font-color:#0000FF;font-family:sans-serif !important;"/>  </b>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr> <br/>
            
            <tr width="100%" style="font-size:9pt;">
                <td width="100%" align="left"  style="padding-left:20px;font-family:sans-serif !important;">
                    <table width="100%" align="left" style="font-family:sans-serif !important;">
                        
                        <tr width="100%">
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Name.Label}" style="font-weight: bold;font-family:sans-serif !important;"/>
                            </td>
                            <td width="30%">
                                <apex:outputText value="{!Vendor_Quote__c.Quote__r.Name}" style="font-family:sans-serif !important;"/>
                            </td>
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Vendor__c.Label}" style="font-weight: bold;font-family:sans-serif !important;"/>
                            </td>
                            <td width="30%">
                                <apex:outputfield value="{!Vendor_Quote__c.Vendor__r.Name}" style="font-family:sans-serif !important;"/>
                            </td>
                        </tr> 
                        
                        <tr width="100%">
                             <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.GL_Department__c.Label}" style="font-weight: bold;font-family:sans-serif !important;"/>
                            </td>
                            <td width="30%">
                                <apex:outputText value="{!Vendor_Quote__c.Quote__r.GL_Department__r.Name}" style="font-family:sans-serif !important;"/>
                            </td>
                            
                            <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputText value="{!Vendor_Quote__c.Quote__r.Job__r.Job_Auto_Number__c}"/>
                            </td>
                        </tr> 
                        
                        <tr width="100%">
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.GL_Code__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                               <apex:outputText value="{!Vendor_Quote__c.Quote__r.GL_Code__r.Name}"/>
                            </td>
                            <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Job__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputText value="{!Vendor_Quote__c.Quote__r.Job__r.Name}"/> 
                            </td>
                        </tr> 
                        
                        <tr width="100%">
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Unit_Type__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputfield value="{!Vendor_Quote__c.Quote__r.Unit_Type__c}"/>
                            </td>
                            <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Schedule_Template__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputText value="{!Vendor_Quote__c.Quote__r.Job__r.Schedule_Template__r.Name}"/>
                            </td>
                        </tr> 
                        <tr width="100%">
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Quantity__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                               <apex:outputField value="{!Vendor_Quote__c.Quote__r.Quantity__c}"/>
                            </td>
                            <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Request_Date__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputField value="{!Vendor_Quote__c.Quote__r.Request_Date__c}"/>
                            </td>
                        </tr> 
                        <tr width="100%">
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Description__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputField value="{!Vendor_Quote__c.Quote__r.Description__c}"/>
                            </td>
                            <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Due_Date__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputField value="{!Vendor_Quote__c.Quote__r.Due_Date__c}"/>
                            </td>
                        </tr> 
                        
                    </table> 
                    
                </td>
            </tr><br/>
            
        </table>
        <table width="100%">      
           <tr width="100%">
                <td align="left">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <tr width="100%">
                <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width="100%">
                                <b> <apex:outputText value="SPEC ITEMS" style="font-size:11pt;font-weight:bold;font-color:#0000FF;font-family:sans-serif !important;"/>  </b>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr> <br/>
             
         <table width="100%" style="font-family:sans-serif !important;">
                <tr width="100%" style="font-size:10pt;">
                    
                    <th width="30%"><b>Spec Name</b></th>
                    
                    <th width="70%"><b>Description</b></th>
                    
                </tr> 
                
                <tr width="100%">
                    
                    <td colspan="2">
                        <hr/>
                    </td>
                    
                </tr>
                
                <tr width="100%" style="font-size:9pt;">
                    <td width="100%" colspan="2">
                        
                            <apex:repeat value="{!vqli}" var="JS" >
                                
                                <table width="100%">
                                    <tr style="font-size:9pt;">
                                        
                                        <td width="30%" style="text-align:left;"  valign="top"><apex:outputField value="{!JS.Name}"/></td> 
                                        <td width="70%" style="text-align:leftt;" valign="top"><apex:outputField value="{!JS.Description__c}"/></td>
                                        
                                    </tr>
                                </table>
                                
                            </apex:repeat><br/>
                    </td>
                </tr>
            </table>   
            
        </table>
    </body>
</apex:page>
<!-- End of Page -->