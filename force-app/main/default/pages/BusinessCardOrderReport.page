<apex:page controller="BusinessCardOrderReportCnt" sidebar="false">

    <!--  contentType="application/vnd.ms-excel#SalesForceExport.xls" cache="true" -->
    <apex:form >
        <apex:pageBlock >

            <center>
                <table>
                    <tr>
                        <td style="font-weight: bold;width:120px;white-space:nowrap">
                            {!$ObjectType.Job__c.Fields.Status__c.Label}
                        </td>
                        <td style="width: 280px;white-space:nowrap">
                            <apex:selectList id="Jobstatus" value="{!JobStatusString }" size="1">
                                <apex:selectOptions value="{!JobStatus}"></apex:selectOptions>
                            </apex:selectList>
                        </td>

                        <td style="font-weight: bold;width:120px;white-space:nowrap">
                            Job Type
                        </td>

                        <td style="width: 280px;white-space:nowrap">
                            <apex:selectList value="{!SringScheduleTypes}" size="1" id="SringScheduleTypes">
                                <apex:selectOptions value="{!ScheduleTypes}" />
                            </apex:selectList>
                        </td>
                    </tr>
                    <br/>
                    <tr>

                        <td colspan="3" style="text-align: center; padding-top: 20px;">
                            <apex:commandbutton value="Search" action="{!SearchSpecs}" />

                        </td>

                    </tr>

                </table>
            </center>

        </apex:pageBlock>

        <apex:pageBlock >
            <apex:outputPanel rendered="{!jw.size>0}">

                <center> <b><apex:outputtext value="Name Tag Report" style="font-size:15px;"> </apex:outputtext></b> </center>
                <br/>

                <div>
                    <table width="100%">

                        <tr>
                            <th width="25%" style="text-align:justify;"><b>Store Name</b></th>
                            <th width="15%" style="text-align:justify;"><b>Title</b></th>
                            <th width="15%" style="text-align:justify;"><b>Name</b></th>
                            <!-- <th width="15%" style="text-align:justify;"><b>Last Name</b></th>-->

                            <th width="15%" style="text-align:justify;"><b>Year Of Hire</b></th>
                            <th width="15%" style="text-align:justify;"><b>Logo</b></th>
                        </tr>
                        <tr>
                            <td colspan="7">
                                <hr color="black" />
                            </td>
                        </tr>

                        <apex:repeat value="{!jw}" var="item">

                            <table width="100%">

                                <tr>
                                    <td>
                                        <table width="100%">

                                            <tr>
                                                <td width="25%" style="text-align:justify;" valign="top">
                                                    <apex:outputField Value="{!item.job.JS_Client__r.Client_Code__c}" />
                                                    <br/>
                                                </td>

                                                <!--  <td width="15%" style="text-align:justify" valign="top">
                              <apex:outputfield Value="{!item.jobspecsStore.Description__c}" rendered="{!item.jobspecsTitle.Description__c='Team Member'}"/><br/>
                              </td>-->

                                                <td width="15%" style="text-align:justify" valign="top">
                                                    <apex:outputField Value="{!item.jobspecsTitle.Description__c}" />
                                                    <br/>
                                                </td>

                                                <td width="15%" style="text-align:justify" valign="top">
                                                    <apex:outputField Value="{!item.jobspecsName.Description__c}" /> &nbsp;
                                                    <apex:outputfield Value="{!item.jobspecsStore.Description__c}" />
                                                    <br/>
                                                </td>

                                                <td width="15%" style="text-align:justify" valign="top">
                                                    <apex:outputField Value="{!item.jobspecsYearofhire.Description__c}" />
                                                    <br/>

                                                </td>

                                                <td width="15%" style="text-align:justify" valign="top">

                                                    <apex:outputField Value="{!item.jobspecsLogo.Description__c}" />
                                                    <apex:outputText value="," rendered="{!item.jobspecsLogo2.Description__c!=null}" />
                                                    <apex:outputField Value="{!item.jobspecsLogo2.Description__c}" />
                                                    <br/>
                                                </td>
                                            </tr>

                                        </table>
                                    </td>
                                </tr>

                            </table>
                        </apex:repeat>

                    </table>
                </div>

            </apex:outputPanel>

            <apex:outputPanel rendered="{!JCONW.size>0}">

                <center> <b><apex:outputtext value="Corporate Office Nameplate" style="font-size:15px;"> </apex:outputtext></b> </center>
                <br/>

                <div>
                    <table width="100%">

                        <tr>
                            <th width="20%" style="text-align:justify;"><b>Name</b></th>
                            <th width="20%" style="text-align:justify;"><b>Title</b></th>
                            <th width="20%" style="text-align:justify;"><b>Year Of Hire</b></th>
                            <th width="20%" style="text-align:justify;"><b>Building</b></th>
                            <th width="20%" style="text-align:justify;"><b>Nameplate Type</b></th>
                        </tr>
                        <tr>
                            <td colspan="5">
                                <hr color="black" />
                            </td>
                        </tr>

                        <apex:repeat value="{!JCONW}" var="item">

                            <table width="100%">

                                <tr>
                                    <td>
                                        <table width="100%">

                                            <td width="20%" style="text-align:justify" valign="top">
