                                                <br/>
                                            </td>

                                            <td width="20%" style="text-align:justify" valign="top">
                                                <apex:outputField Value="{!item.jobspecsTitle.Description__c}" />
                                                <br/>
                                            </td>

                                            <td width="20%" style="text-align:justify" valign="top">
                                                <apex:outputField Value="{!item.jobspecsYearofhire.Description__c}" />
                                                <br/>
                                            </td>

                                            <td width="20%" style="text-align:justify" valign="top">
                                                <apex:outputField Value="{!item.jobspecsBuilding.Description__c}" />
                                                <br/>
                                            </td>

                                            <td width="20%" style="text-align:justify" valign="top">
                                                <apex:outputtext Value="{!item.jobspecsNameplateType}" />
                                                <br/>
                                            </td>

                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </apex:repeat>
                    </table>
                </div>
