<apex:page controller="DisplayJobsforClientContact" tabStyle="Job__c" readOnly="true" sidebar="false" docType="html-5.0" applyBodyTag="False" standardStylesheets="true" applyHtmlTag="False"  showHeader="False">



    <head>
        <style>
            .hd {
                text-align: right;
                padding-right: 20px!important;
            }
            
            .labelCol2 {
                font-size: 1.0em
            }
            
            ;
      
        .customImage{ height: 10px; width: 10px; }
