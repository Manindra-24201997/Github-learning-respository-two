                                                    <div class="slds-form-element__control"   style="background-image:url('{!URLFOR($Resource.BannerCMNForm, 'BannerCMNForm.PNG')}');background-repeat:no-repeat;height:400vw;width:55vw;position: absolute;background-size: contain;">

                                                         <div style="padding-left:17.7vw;padding-top:0.8vw;">
                                                            <div style="position: absolute;">
