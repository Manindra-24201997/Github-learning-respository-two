                                                                <br/>
                                                                <span id="Date" style="font-family: AGBookTTBol;font-size:2vw;color:#FECD08;line-height:2"><b>{!CMNFlyerDate}</b></span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                                <span id="Time" style="font-family: AGBookTTBol;font-size:2vw;color:#FECD08;"><b>{!CMNFlyerTime}</b></span >    
