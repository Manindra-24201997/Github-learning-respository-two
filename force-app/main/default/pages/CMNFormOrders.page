                                                                <span id="TimeB" style="font-family: AGBookTTBol;font-size:1.5vw;color:#FECD08;"><b>{!CMNBannerTime}</b></span >
                                                            </div>

                                                            <div style="padding-top:8.5vw;position: absolute;">
                                                                <span id="EventB" style="font-family: AGBookTTBol;font-size:1.1vw;color:#57585A;"><b>{!CMNBannerEventDetails}</b></span >                  
                                                            </div>

                                                        </div>  
                                                    </div>
                                                </div>
                                            </aside>
                                            
                                             <aside class="slds-col slds-size--1-of-3 slds-medium-size--2-of-6 slds-large-size--5-of-12">
