                                                                             <apex:outputText value="{!clientcontact.Client__r.Billing_Street__c }"/><br/>
                                                                             <apex:outputText value=" {!clientcontact.Client__r.Billing_City__c}, "/>
                                                                             <apex:outputText value=" {!clientcontact.Client__r.Billing_State__c}"/>
                                                                             <apex:outputText value=" {!clientcontact.Client__r.Billing_Postal_Code__c}"/><br/>
                                                                             <apex:outputText value=" {!clientcontact.Client__r.Phone__c}"/></b>
                                                                   </td>
                                                                   <td>
                                                                       <apex:image url="{!URLFOR($Resource.CMNForm, 'CMNFlyerFooters.PNG')}" style="float:right;width:65%" />
                                                                   </td>
                                                               </tr>
                                                               </table>

                                                            </div>
                                                             </div>

                                                    </div>
                                                </div>
                                            </aside>
                                            
                                              
                                       
                                           <aside class="slds-col slds-size--1-of-3 slds-medium-size--3-of-6 slds-large-size--6-of-12">
                                                <div class="slds-form-element slds-p-top--medium slds-p-left--medium" >
                                                    <label class="slds-form-element__label"><font style="color: SteelBlue;font-size:16px;"><b>Approved</b></font></label>
                                                    <div class="slds-form-element__control">
                                                        <div style="padding-top:15px;">
                                                            <label class="slds-checkbox" >
                                                                <apex:inputCheckbox value="{!FlyerApproved}" />   
                                                                <span class="slds-checkbox--faux"></span>
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </aside>

                                         
                                            <aside class="slds-col slds-size--2-of-3 slds-medium-size--4-of-6 slds-large-size--7-of-12">
