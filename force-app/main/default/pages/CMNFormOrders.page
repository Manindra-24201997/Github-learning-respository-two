                                                        <div style="padding-left:17.6vw;padding-top:0.8vw;">
                                                            <div style="position: absolute;">
                                                                    <span id="NameB" style="font-family: AGBookTTBol;font-size:3vw;color:#57585A;line-height:2.5vw;"><b>{!CMNBannerNameofEvent}</b></span>
                                                            </div>

                                                            <div style="padding-top:5.8vw;position: absolute;">
                                                                <span id="DateB" style="font-family: AGBookTTBol;font-size:1.5vw;color:#FECD08;line-height:2vmin;"><b>{!CMNBannerDate}</b></span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                                <span id="TimeB" style="font-family: AGBookTTBol;font-size:1.5vw;color:#FECD08;"><b>{!CMNBannerTime}</b></span >
                                                            </div>

                                                            <div style="padding-top:8.5vw;position: absolute;">
                                                                <span id="EventB" style="font-family: AGBookTTBol;font-size:1.1vw;color:#57585A;"><b>{!CMNBannerEventDetails}</b></span >                  
                                                            </div>

                                                        </div>  
                                                    </div>
                                                </div>
                                            </aside>

                                        </div>

                                    </div>
                                </main>
                            </div>

