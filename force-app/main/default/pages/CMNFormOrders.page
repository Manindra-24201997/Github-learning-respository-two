                                                <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                    <label class="slds-form-element__label required"><font style="color: SteelBlue;font-size:16px;"><b>Name of Event:</b></font></label>
                                                    <div class="slds-form-element__control">
                                                        <apex:outputPanel layout="block" styleClass="requiredInput">
                                                            <apex:inputText value="{!CMNBannerNameofEvent}" maxlength="36"  onkeyup="document.getElementById('NameB').innerHTML = this.value;" styleClass="slds-input" html-placeholder="36 Characters with spaces">
                                                                 <apex:actionSupport event="onkeyup" rerender="CMNBForm"/>
                                                            </apex:inputText>
                                                        </apex:outputPanel>
                                                    </div>
                                                </div>
                                            </aside>

                                            <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                                <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                    <label class="slds-form-element__label required"><font style="color: SteelBlue;font-size:16px;"><b>Time:</b></font></label>
                                                    <div class="slds-form-element__control">
                                                        <apex:outputPanel layout="block" styleClass="requiredInput">
                                                            <apex:inputText value="{!CMNBannerTime}"  onkeyup="document.getElementById('TimeB').innerHTML = this.value;" styleClass="slds-input" html-placeholder="12:00 p.m. – 5:30 p.m.">
