                                                    <div class="slds-form-element__control">
                                                        <div style="padding-left:26px;padding-top:15px;">
                                                            <label class="slds-checkbox" >
                                                                <apex:inputCheckbox value="{!BannerApproved}" />   
                                                                <span class="slds-checkbox--faux"></span>
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            </aside>

                                        </div>
                                </main>
                                </div>
                                
                                
                            </div>

                        </apex:outputPanel>

                    </apex:pageBlock>

                </apex:outputPanel>
            </apex:form>
        </div>
