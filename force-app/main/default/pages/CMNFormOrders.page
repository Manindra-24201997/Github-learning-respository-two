                                                    <div class="slds-form-element__control">
                                                        <apex:outputPanel layout="block" styleClass="requiredInput">
                                                            <apex:inputText value="{!CMNBannerDate}" maxlength="26" onkeyup="document.getElementById('DateB').innerHTML = this.value;" styleClass="slds-input" html-placeholder="26 Characters with Spaces">
