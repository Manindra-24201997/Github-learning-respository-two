<apex:page controller="GanttExpVfPageCtrl" sidebar="false"  showHeader="false" readOnly="false" standardStylesheets="true"  applyBodyTag="false" applyHtmlTag="false" docType="html-5.0">
    
   <apex:slds />
    <apex:includeScript value="{!URLFOR($Resource.DhtmlGanttJs)}"/>
    <apex:stylesheet value="{!URLFOR($Resource.DhtmlGanttCss)}"/>
    <apex:stylesheet value="{!URLFOR($Resource.DhtmlGanttControlCss)}"/>   
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Type" content="text/html;charset=utf-8"/>
    <style>
        
        html, body {
        height: 100%;
        padding: 0px;
        margin: 0px;
        overflow: hidden;
        }
        .weekend{
        background: #F0DFE5 !important;
        }
        .gantt_tooltip {
        height:80px;
        font-size: 14px;
        line-height: 22px;
        }
        .gantt_task_line {
        border-radius:8px !important;
        }
    </style>
    
    <body onload="doInit()">
        <div class="slds">
            
            
            <apex:form >
                <div class="gantt_control">
                    
                    <div class="slds-grid slds-wrap">
                        
                        
                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--2-of-12">
                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                <label class="slds-form-element__label" style="font-family: 'Salesforce Sans';font-size: 13px;"><b>Campaign</b> </label>
                                <div class="slds-form-element__control" >
                                    <apex:selectList id="campg" value="{!strCampaignName}" size="1" onchange="campp()" StyleClass="slds-input">
                                        <apex:selectOptions value="{!Campaigns}"></apex:selectOptions>
                                        <apex:actionFunction name="campp" />
                                    </apex:selectList>
                                </div>
                            </div>
                        </aside>
                        
                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--2-of-12">
                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                <label class="slds-form-element__label"  style="font-family: 'Salesforce Sans';font-size: 13px;"><b>Client</b> </label>
                                <div class="slds-form-element__control" >
                                    <apex:selectList id="client" value="{!strClientName}" size="1" onchange="clien()" StyleClass="slds-input">
                                        <apex:selectOptions value="{!Clients}"></apex:selectOptions>
                                        <apex:actionFunction name="clien"/>
                                    </apex:selectList>
                                </div>
                            </div>
                        </aside>
                        
                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--2-of-12">
                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                <label class="slds-form-element__label"  style="font-family: 'Salesforce Sans';font-size: 13px;"><b>Media Type</b> </label>
                                <div class="slds-form-element__control" >
                                    <apex:selectList id="media" value="{!strmediatype}" size="1" onchange="media()" StyleClass="slds-input">
                                        <apex:selectOptions value="{!Mediatype}"></apex:selectOptions>
                                        <apex:actionFunction name="media" />
                                    </apex:selectList>
                                </div>
                            </div>
                        </aside>
                        
                        
                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--2-of-12">
                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                <label class="slds-form-element__label"  style="font-family: 'Salesforce Sans';font-size: 13px;"><b>Schedule Template</b> </label>
                                <div class="slds-form-element__control" >
                                    <apex:selectList id="schd" value="{!strscheduletemp}" size="1" onchange="schd()" StyleClass="slds-input">
                                        <apex:selectOptions value="{!scheduletemp}"></apex:selectOptions>
                                        <apex:actionFunction name="schd" />
                                    </apex:selectList>
                                </div>
                            </div>
                        </aside>
                        
                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--2-of-12">
                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                <label class="slds-form-element__label"  style="font-family: 'Salesforce Sans';font-size: 13px;"><b>Job Status</b> </label>
                                <div class="slds-form-element__control" >
                                    <apex:selectList id="status" value="{!JobStatusString}" size="1" onchange="status()" StyleClass="slds-input">
                                        <apex:selectOptions value="{!jobStatus}"></apex:selectOptions>
                                        <apex:actionFunction name="status" />
                                    </apex:selectList>
                                </div>
                            </div>
                        </aside>
                        
                        
                        
                        
                        
                        
                    </div>
                    
                    
                </div>
                
                
                <div id="gantt_here" style='width:100%; height:calc(90vh - 84px);'></div>
                
                
                <div id="loadingDiv" style="display:none;position: fixed; left: 0; top: 0; bottom: 0; right: 0; z-index: 1001; margin: 15% 50%">
                    <div style="display: inline-block; padding: 2px; background-color: #fff; width: 125px;">
                        <img src="/img/loading.gif" style="float: left; margin: 8px;" />
                        <span style="display: inline-block; padding: 10px 0px;">Please Wait...</span>
                    </div>
                </div>
                
                <div class="gantt_control">    
                    
                    <input type="radio" id="scale1" class="gantt_radio" name="scale" value="day"/>
                    <label for="scale1">Day</label>
                    
                    <input type="radio" id="scale2" class="gantt_radio" name="scale" value="week" checked="true"/>
                    <label for="scale2">Week</label>
                    
                    <input type="radio" id="scale3" class="gantt_radio" name="scale" value="month"/>
                    <label for="scale3">Month</label>
                    
                    <input type="radio" id="scale5" class="gantt_radio" name="scale" value="year" />
                    <label for="scale5">Year </label>
                    
                </div>
            </apex:form>
        </div>
        
        <script>
        
        function doInit(){
            var dataLoop=[];
            var taskdata;
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.GanttExpVfPageCtrl.getGanttTasks}','{!strCampaignName}','{!strClientName}','{!strmediatype}','{!strscheduletemp}',
                '{!JobStatusString}',                
                function(result, event){
                    if (event.status) {
                        console.log('task length---'+result.length);
                        console.log('task rows---'+JSON.stringify(result));
                        for(var i=0;i<result.length;i++){
                            for(var j = 0;j < result[i].JobSuite__Job_Task__r.length;j++)
                            {
                                var r = result[i].JobSuite__Job_Task__r[j];
                                console.log('I val>>>'+i);
                                var stdate=new Date(r.JobSuite__Revised_Due_Date__c);
                                console.log('task Befor Format due date---'+stdate);
                                stdate=dateFormat(stdate);
                                console.log('task After format due date---'+stdate);
                                var enddate=new Date(r.JobSuite__Revised_Due_Date__c);
                                enddate=dateFormat(enddate);
                                
                                var color=['Blue','BlueViolet','Brown','CadetBlue','Chocolate','Coral','CornflowerBlue','Crimson','DarkBlue','DarkCyan','DarkGoldenRod','DarkGreen','DarkMagenta','DarkOliveGreen',
                                           'Black','Darkorange','DarkOrchid','DarkSlateBlue','DarkViolet','DeepPink','DeepSkyBlue','DodgerBlue','FireBrick','ForestGreen','GoldenRod','Gray','Green',
                                           'HotPink','IndianRed','Indigo','Magenta','Maroon','MediumBlue','MediumOrchid','MediumPurple','MediumSeaGreen','MediumSlateBlue','MediumVioletRed','MidnightBlue','Navy',
                                           'Olive','Orange','OrangeRed','Orchid','PaleVioletRed','Peru','Purple','Red','RoyalBlue','SaddleBrown','Salmon','SandyBrown','SeaGreen','Sienna','SlateBlue',
                                           'SteelBlue','Teal','Tomato','OliveDrab','Blue','BlueViolet','Brown','CadetBlue','Chocolate','Coral','CornflowerBlue','Crimson','DarkBlue','DarkCyan','DarkGoldenRod',
                                           'DarkGreen','DarkMagenta','DarkOliveGreen','Black','Darkorange','DarkOrchid','DarkSlateBlue','DarkViolet','DeepPink','DeepSkyBlue','DodgerBlue','FireBrick',
                                           'ForestGreen','GoldenRod','Gray','Green','HotPink','IndianRed','Indigo','Magenta','Maroon','MediumBlue','MediumOrchid','MediumPurple','MediumSeaGreen','MediumSlateBlue',
                                           'MediumVioletRed','MidnightBlue','Navy','Olive','Orange','OrangeRed','Orchid','PaleVioletRed','Peru','Purple','Red','RoyalBlue','SaddleBrown','Salmon','SandyBrown',
                                           'SeaGreen','Sienna','SlateBlue','SteelBlue','Teal','Tomato','OliveDrab','Blue','BlueViolet','Brown','CadetBlue','Chocolate','Coral','CornflowerBlue','Crimson',
                                           'DarkBlue'];
                                dataLoop.push({"id":r.Id, "text":r.Name + ' - #' +r.JobSuite__Job__r.JobSuite__Job_Auto_Number__c, "start_date":stdate,  "duration":1, "color":color[i], "progress":0, "open": true});
                            }
                            parseGanttData(dataLoop);
                        }
                    }
                });
            function dateFormat(fromdate){
                var dd = fromdate.getDate();
                var mm = fromdate.getMonth()+1; 
                var yyyy = fromdate.getFullYear();
                if(dd<10) 
                {
                    dd='0'+dd;
                } 
                if(mm<10) 
                {
                    mm='0'+mm;
                } 
                var ftdate = dd+'-'+mm+'-'+yyyy;
                return ftdate;
            }
            function parseGanttData(dataLoop){
                
                var demo_tasks1 = {
                    "data":dataLoop
                };  
                gantt.ext.zoom.init(zoomConfig);
                gantt.ext.zoom.setLevel("week");
                gantt.ext.zoom.attachEvent("onAfterZoom", function(level, config){
                    document.querySelector(".gantt_radio[value='" +config.name+ "']").checked = true;
                })
                gantt.plugins({
                    tooltip: true
                });
                gantt.attachEvent("onGanttReady", function(){
                    var tooltips = gantt.ext.tooltips;
                    tooltips.tooltip.setViewport(gantt.$task_data);
                });
                gantt.templates.tooltip_text = function(start,end,task){
                    var stdate=dateFormat(task.start_date);
                    var enddate=dateFormat(task.end_date);//.setDate(task.end_date.getDate()-1);
                    
                    return "<b>Name:</b> "+task.text+"<br/><b>Start Date:</b> "+stdate+"<br/><b>End Date:</b>"+enddate;
                };
                gantt.config.row_height = 30;
                gantt.config.columns = [
                    {name:"text", label:"Name",align: "center"},
                    {name:"start_date", label:"Start Date", align: "center"},
                    {name:"end_date",   label:"End Date",   align: "center" ,width:"100" }                       
                ];
                gantt.attachEvent("onTaskDblClick", function(id,e){
                    var task = gantt.getTask(id);
                    window.location.href='/'+task.id;
                    return false;
                });  
                gantt.attachEvent("onAfterTaskDrag", function (id, mode) {
                    var task = gantt.getTask(id);
                    if (mode == gantt.config.drag_mode.progress) {
                        var pr = Math.floor(task.progress * 100 * 10) / 10;
                        //gantt.message(task.text + " is now " + pr + "% completed!");
                    } else {
                        var convert = gantt.date.date_to_str("%H:%i, %F %j");
                        var s = convert(task.start_date);
                        var e = convert(task.end_date);
                        //gantt.message(task.text + " starts at " + s + " and ends at " + e);
                        
                    }
                    var reSchedule = confirm("Would you also like to recreate the schedule?");
                    if (reSchedule == true) {
                        updateDates(task.id,task.start_date,task.end_date,true);
                    } else {
                        updateDates(task.id,task.start_date,task.end_date,false);
                    }
                    document.getElementById('gantt_here').style.display = "none";
                    document.getElementById('loadingDiv').style.display = "block";
                    
                });
                gantt.attachEvent("onBeforeTaskChanged", function (id, mode, old_event) {
                    var task = gantt.getTask(id);
                    if (mode == gantt.config.drag_mode.progress) {
                        if (task.progress < old_event.progress) {
                            //gantt.message(task.text + " progress can't be undone!");
                            return false;
                        }
                    }
                    return true;
                });
                
                gantt.attachEvent("onBeforeTaskDrag", function (id, mode) {
                    var task = gantt.getTask(id);
                    var message = task.text + " ";
                    
                    if (mode == gantt.config.drag_mode.progress) {
                        message += "progress is being updated";
                    } else {
                        message += "is being ";
                        if (mode == gantt.config.drag_mode.move)
                            message += "moved";
                        else if (mode == gantt.config.drag_mode.resize)
                            message += "resized";
                    }
                    //gantt.message(message);
                    return true;
                });
                gantt.config.drag_links = false;
                gantt.init("gantt_here", new Date(2020,01, 01), new Date(2021,01, 01));
                gantt.parse(demo_tasks1);
            }
            function updateDates(id,startdate,enddate,reSchedule){             
                Visualforce.remoting.Manager.invokeAction(
                    '{!$RemoteAction.GanttExpVfPageCtrl.updateJobRec}',id,startdate,enddate,reSchedule,           
                    function(result, event){
                        if (event.status) {
                            if(result=='ok'){
                                doInit();
                                document.getElementById('loadingDiv').style.display = "none";
                                document.getElementById('gantt_here').style.display = "block";
                            }
                        }
                    });
            }
            
            var weekScaleTemplate = function (date) {
                var dateToStr = gantt.date.date_to_str("%d %M");
                var endDate = gantt.date.add(gantt.date.add(date, 1, "week"), -1, "day");
                return dateToStr(date) + " - " + dateToStr(endDate);
            };
            
            var daysStyle = function(date){
                if(date.getDay() === 0 || date.getDay() === 6){
                    return "weekend";
                }
                return "";
            };
            var zoomConfig = {
                levels: [
                    {
                        name:"day",
                        scale_height: 27,
                        min_column_width:80,
                        scales:[
                            {unit: "day", step: 1, format: "%d %M"}
                        ]
                    },
                    {
                        name:"week",
                        scale_height: 80,
                        min_column_width:50,
                        scales:[
                            {unit: "month", step: 1, format: "%F, %Y"},
                            {unit: "week", step: 1, format: weekScaleTemplate},
                            {unit: "day", step:1, format: "%j %D", css:daysStyle }
                        ]
                    },
                    {
                        name:"month",
                        scale_height: 80,
                        min_column_width:120,
                        scales:[
                            {unit: "month", format: "%F, %Y"},  
                            {unit: "week", step: 1, format: weekScaleTemplate}
                            
                        ]
                    },
                    {
                        name:"quarter",
                        height: 50,
                        min_column_width:90,
                        scales:[
                            {unit: "month", step: 1, format: "%M"},
                            {
                                unit: "quarter", step: 1, format: function (date) {
                                    var dateToStr = gantt.date.date_to_str("%M");
                                    var endDate = gantt.date.add(gantt.date.add(date, 3, "month"), -1, "day");
                                    return dateToStr(date) + " - " + dateToStr(endDate);
                                }
                            }
                        ]
                    },
                    {
                        name:"year",
                        scale_height: 50,
                        min_column_width: 30,
                        scales:[
                            {unit: "year", step: 1, format: "%Y"}
                        ]
                    }
                ]
            };
            
        }
        function zoomIn(){
            gantt.ext.zoom.zoomIn();
        }
        function zoomOut(){
            gantt.ext.zoom.zoomOut()
        }
        
        var radios = document.getElementsByName("scale");
        for (var i = 0; i < radios.length; i++) {
            radios[i].onclick = function (event) {
                gantt.ext.zoom.setLevel(event.target.value);
            };
        }
        </script>
    </body> 
    
</apex:page>