<apex:page controller="CustomOrderRequestFormExt" sidebar="true" docType="html-5.0" applyBodyTag="False" standardStylesheets="false" applyHtmlTag="False" showHeader="False">
    <style>
        .sfdc_richtext img {
        border: 0;
        height: 30%;
        width: 30%;
        }
        
        .button2 {
        background-color: #FFD700;
        font-weight: bold;
        color: Black;
        }
        
        #ProductsTable img {
        opacity: 50%;
        width: 20% !Important;
        }
        
        .customImage{ height: 10px; width: 10px; }
        #rcorners1 {
        border-radius:0%;
        border: 1px solid #cccccc;
        padding: 0px; 
        width: 100%;
        height: 0%;
        }
        #pagemessage
        {
        color:blue;
        }
        .required:after { content:" *";  color: Red;font:bold;}
        
        html,html body
        {
        overflow: auto;
        -webkit-overflow-scrolling:auto;
        }
        body
        {
        position:absolute;left:0;right:0;top:0;bottom:0;
        margin:0;
        }
        
        .slds .slds-table .slds-truncate 
        {
        min-width: 52px !important;
        max-width: 125px !important;
        }
        
        .slds-checkbox .slds-checkbox--faux
        {
        border: 2px solid lightslategrey !important;
        } 
        
        .slds-card cStoreFront
        {
        padding: .5rem .5rem .5rem .5rem !important;
        background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgba(32, 92, 159, 0), rgb(32, 92, 159));
        }
        
    </style>
    <script>
    function myFunction() {
        var x = document.getElementById("myDIV");
        var y=document.getElementById("waitmsg");
        x.style.opacity= 0.3;
        y.style.display = "block";
    }
    </script>
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0122, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        
        <body>
            
            <div id="waitmsg" style="display:none;position:absolute;top:50%;left:50%">
                <center>
                    <h2>
                        <img src="/img/loading.gif"/>  Please wait...
                    </h2>
                </center>
            </div>
            
            <div class="slds" id="myDIV" >
                <apex:form enctype="multipart/form-data" html-novalidate="novalidate" id="CusOrderID">
                    
                    <apex:image value="{!$Resource.LovesHeaderLogo}" width="250" height="250" style="margin-left:2%;"/>
                    <apex:commandButton value="Place Order" action="{!save}" styleClass="slds-button slds-button--brand" onclick="myFunction()" style="float:right;margin-right:2.75%;margin-top:1.5%;"/>
                    <apex:commandButton value="Back" action="{!back}" styleClass="slds-button slds-button--neutral" style="float:right;margin-right:1%;margin-top:1.5%;"/>
                    <br/>
                    <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" style="width:94%;margin-left:2%;">
                        <apex:pageMessages />
                    </div> 
                    
                    <br/>
                    <div style="background-color:#e2e4e6;width:95%;margin-left:2%;">
                        <h3 class="slds-section-title"><b>&nbsp;Custom Order Request Form</b></h3>
                    </div>
                    
                    <br/>
                    
                    <div class="slds-grid slds-wrap" style="width:95%;margin-left:2%;">
                        <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                            
                            <div class="slds-grid slds-wrap">
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b> <apex:outputText Value="Notice"></apex:outputText></b></label>
                                        <div class="slds-form-element__control">
                                            
                                            <div style="color:red">
                                                * NEW Custom Orders include a <b> $150 Custom Project Fee</b> and a turnaround time of at least 4 weeks.
                                            </div>
                                            
                                        </div>
                                    </div>
                                </aside><br/><br/>
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b> <apex:outputText Value="Items Needed"></apex:outputText> </b></label>
                                        <div class="slds-form-element__control">
                                            <apex:outputPanel >
                                                <apex:selectList value="{!ItemsNeededList}" id="SelectItemsNeededList" multiselect="true" size="8" styleClass="slds-select slds-m-right--medium">
                                                    <apex:selectoptions value="{!ItemsNeeded}"></apex:selectoptions>
                                                </apex:selectList>
                                                
                                                <div style="color:black">** To Select multiple Items, press ctrl, then click the items</div>
                                            </apex:outputPanel>                                                                
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label required"><b> <apex:outputLabel > Upload photo of installation area upto 25mb file size</apex:outputLabel> </b></label>
                                        <div class="slds-form-element__control">
                                            <apex:outputPanel layout="block" styleClass="requiredInput">
                                                <div class="requiredBlock" style="height:20px;"></div>
                                                <apex:inputfile value="{!myfileattach.body}" filename="{!myfileattach.Name}" styleClass="slds-input"/>
                                                <br/>
                                                <div style="color:red">(Required)</div>
                                            </apex:outputPanel>                                                             
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b><apex:outputText Value="Turn-Time"></apex:outputText></b></label>
                                        <div class="slds-form-element__control">
                                            <apex:outputPanel >
                                                <apex:selectList value="{!TurnTimeString}" id="SelectTurnTimeString" multiselect="false" size="1" styleClass="slds-select slds-m-right--medium">
                                                    <apex:selectoptions value="{!TurnTime}"></apex:selectoptions>
                                                </apex:selectList>
                                            </apex:outputPanel>                                                              
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b> <apex:outputText value="Quantity Needed"></apex:outputText> </b></label>
                                        <div class="slds-form-element__control">
                                            <apex:inputTextarea value="{!CustomQuantityNeeded}"  styleClass="slds-input"></apex:inputTextarea>                                                               
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b><apex:outputText value="Provide Height and Width Measurements in Inches "></apex:outputText> </b></label>
                                        <div class="slds-form-element__control">
                                            <apex:inputTextarea value="{!CustomMeasurements}" styleClass="slds-input"></apex:inputTextarea>                                                               
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b><apex:outputText value="Explain request in detail"></apex:outputText></b></label>
                                        <div class="slds-form-element__control">
                                            <apex:inputTextarea value="{!Customrequest}"  styleClass="slds-input"></apex:inputTextarea>                                                       
                                        </div>
                                    </div>
                                </aside>
                                
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b>  <apex:outputText value="Explain, in detail, what signs/banners/etc. need to say"></apex:outputText> </b></label>
                                        <div class="slds-form-element__control">
                                            <apex:inputTextarea value="{!Customneedtosay}" styleClass="slds-input"></apex:inputTextarea>                                                           
                                        </div>
                                    </div>
                                </aside>
                                
                                <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                    <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                        <label class="slds-form-element__label"><b> <apex:outputText value="Explain, in detail, where items will be installed"></apex:outputText></b></label>
                                        <div class="slds-form-element__control">
                                            <apex:inputTextarea value="{!Customneedtogo}" styleClass="slds-input"></apex:inputTextarea>                                                    
                                        </div>
                                    </div>
                                </aside>
                                
                            </div>
                            <apex:commandButton value="Place Order" action="{!save}" styleClass="slds-button slds-button--brand" onclick="myFunction()" style="float:right;margin-right:2.75%;margin-top:1.5%;"/>
                            <apex:commandButton value="Back" action="{!back}" styleClass="slds-button slds-button--neutral" style="float:right;margin-right:1%;margin-top:1.5%;"/>
                            <br/>
                        </main>
                    </div>  
                    
                </apex:form>
            </div>
        </body>
    </html>
</apex:page>