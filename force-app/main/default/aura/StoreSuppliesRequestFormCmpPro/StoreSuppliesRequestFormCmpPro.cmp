                            <aura:if isTrue="{!v.showmaterialitems}">
                                <aura:if isTrue="{!!v.isMobile}">
                                    <!--<aura:if isTrue="{!empty(v.MaterialItems)}">
                                      <aura:if isTrue="{!v.boolval}">
                                            <p style="margin:2rem 4rem;"><b>No records found for the search criteria entered</b></p>
                                        </aura:if>
                                        <aura:set attribute="else">-->
                                    <aura:if isTrue="{!!v.isMobile}">
                                        <lightning:input aura:id="MaterialItemNameString" name="ItemSearch" label=""  style = "float:left;" placeholder="Enter material item search" class="" onchange="{!c.onMisearchname}" type="search"/>  
                                        
                                        <lightning:button label="Add To Cart" title="Add To Cart" class="keyInput" onclick="{!c.addItemToCart}" disabled="{!empty(v.MaterialItems)}"/>
                                        </aura:if>
                                    <br/>  
                                    <div class="slds-grid slds-gutters slds-wrap" style="margin-top: 45px;">
                                        <aura:iteration items="{!v.MaterialItems}" var="item">  
                                            
                                            <div class="slds-col slds-size_3-of-12" >
                                                <br/>  
                                                <span >
                                                    <aura:if isTrue="{!empty(item.value.ContentVersionId)}">
                                                        <br/><br/><br/><br/><br/><br/><br/><br/><br/><br/><br/>
                                                        <aura:set attribute = "else">    
                                                            <br/> <img src="{!v.prefixURL + item.value.ContentVersionId}" class="slds-truncate" width="200" height="30" alt="No Image"/><br/>
                                                        </aura:set>
                                                    </aura:if>
                                                    <span style = "word-wrap:break-word;white-space:pre-wrap;">
                                                        <b style="{!'color:' + item.value.greycolor}">{!item.value.MI.Name}</b><br/>
                                                        {!item.value.MI.Description__c}<br/>
                                                        <b>Package Type:</b> {!item.value.MI.Package_Type__c}<br/>
                                                        <aura:if isTrue="{!item.value.MI.Out_of_Stock__c}">
                                                            <b style="color:red;">{!v.stockLables[0]} </b><br/>
                                                            <b>{!v.stockLables[1]} : </b><lightning:formattedDateTime value="{!item.value.MI.Re_Stocking__c}" year="numeric" month="numeric" day="numeric"/>
                                                           
                                                        </aura:if>
                                                    </span>
                                                    <aura:if isTrue="{!item.value.MI.Out_of_Stock__c==false}">
                                                        <div class="slds-checkbox" >
                                                            <label class="slds-checkbox">
                                                                <ui:inputCheckbox value="{!item.value.checked}"  change="{!c.onCheck}"/>
                                                                <span class="slds-checkbox--faux" />                                
                                                            </label>
                                                        </div>
                                                    </aura:if>
                                                </span>
                                                <br/>
                                            </div>
                                        </aura:iteration>
                                    </div>
                                    
                                    <aura:if isTrue="{!!v.isMobile}">
                                        <lightning:button label="Add To Cart" title="Add To Cart" class="slds-float_right margins" onclick="{!c.addItemToCart}" disabled="{!empty(v.MaterialItems)}"/>
                                    </aura:if>
                                    <br/><br/>
                                    
