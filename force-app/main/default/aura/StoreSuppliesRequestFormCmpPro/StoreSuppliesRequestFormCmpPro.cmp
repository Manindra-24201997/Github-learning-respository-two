                                    <aura:set attribute="else">
                                        <hr style="display: block;margin: 1rem 0 1rem 0;border-top: 1px solid rgb(221, 219, 218);"/>
                                        <div class="showScroll" style="margin-top:45px;">
                                            <ui:scrollerWrapper class="scrollerSizemob">
                                                <aura:iteration items="{!v.MaterialItems}" var="item">
                                                    <table>
                                                        <tr>
                                                            <td colspan="2" width="80%">
                                                                <img src="{!v.prefixURL + item.value.ContentVersionId}" width="150" height="30" alt="No Image"/>
                                                                <br/><b>{!item.value.MI.Name}</b><br/>
                                                                {!item.value.MI.Description__c}<br/>
                                                                <b>Package Type:</b> {!item.value.MI.Package_Type__c}<br/>
