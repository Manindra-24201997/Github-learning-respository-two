                                                        <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Finished Goods</label><br/><br/>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!items == 'Forms'}" >
                                                        <img src="{!$Resource.Forms}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                        <label class="slds-form-element__label"  style=" margin-left: 28px;white-space: nowrap;align:center;" id="{!idx}">Forms</label><br/><br/>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!items == 'Fountain'}" >
                                                        <img src="{!$Resource.Fountain}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                        <label class="slds-form-element__label"  style=" margin-left: 21px;white-space: nowrap;align:center;" id="{!idx}">Fountain</label><br/><br/>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!items == 'Fuel Pumps'}" >
                                                        <img src="{!$Resource.FuelPump}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                        <label class="slds-form-element__label"  style=" margin-left: 5px;white-space: nowrap;align:center;" id="{!idx}">Fuel Pumps</label><br/><br/>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!items == 'Gas Desk'}" >
                                                        <img src="{!$Resource.DieselGasDesk}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                        <label class="slds-form-element__label"  style=" margin-left: 13px;white-space: nowrap;align:center;" id="{!idx}">Gas Desk</label><br/><br/>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!items == 'Literature'}" >
                                                        <img src="{!$Resource.Literature}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                        <label class="slds-form-element__label"  style=" margin-left: 15px;white-space: nowrap;align:center;" id="{!idx}">Literature</label><br/><br/>
                                                    </aura:if>
                                                    
                                                    <aura:if isTrue="{!items == 'Loss Prevention'}" >
                                                        <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
