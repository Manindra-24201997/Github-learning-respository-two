                                                                    <b style="color:red;">{!v.stockLables[0]} </b><br/>
                                                                    <b>{!v.stockLables[1]} : </b><lightning:formattedDateTime value="{!item.value.MI.Re_Stocking__c}" year="numeric" month="numeric" day="numeric"/>

                                                                </aura:if><br/>
                                                            </td>
                                                            <td width="20%" class="slds-text-align_center" style="vertical-align: top;">
                                                                <aura:if isTrue="{!item.value.MI.Out_of_Stock__c==false}">
                                                                    <div class="slds-checkbox" style=" padding-top: 35px;">
                                                                        <label class="slds-checkbox">
                                                                            <ui:inputCheckbox value="{!item.value.checked}"  />
                                                                            <span class="slds-checkbox--faux" />                                
                                                                        </label>
                                                                    </div>
                                                                </aura:if>
                                                            </td>
                                                        </tr>
                                                        
                                                    </table>
                                                    <hr style="display: block;margin: 0 0 1rem 0;border-top: 1px solid rgb(221, 219, 218);"/>
                                                </aura:iteration>
                                            </ui:scrollerWrapper>
                                        </div>
                                    </aura:set>
                                </aura:if>
                            </aura:if>
                        </lightning:accordionSection>
                        
                    </lightning:accordion>
                </ui:scrollerWrapper>
            </div>
            
        </aura:if>
        <!--===========================================*End of Search criteria Layout*=====================================-->
        
        
        
        
        <!--===========================================*ViewCartSection*=====================================-->
        <aura:if isTrue="{!v.ShowCartSection}">
            <lightning:card>
                <aura:set attribute="title">
                    <aura:if isTrue="{!!v.isMobile}">
                        <img src="{!$Resource.LovesHeaderLogo}" width="250" height="250"/>
                    </aura:if>
                </aura:set>  
                <aura:set attribute="actions">
                    <lightning:button variant="neutral"
                                      label="Continue Shopping"
                                      disabled="{!v.isSpinner}"
                                      title="Continue Shopping"
                                      onclick="{!c.continueShopping}" class="buttonClass"/>
                    
                    
                    <lightning:button variant="neutral"
                                      label="Cancel Order"
                                      title="Cancel Order"
                                      disabled="{!v.isSpinner}"
                                      onclick="{!c.cancelorder}" class="buttonClass"/>
                    
                    <lightning:button variant="brand"
                                      label="Place Order"
                                      disabled="{!v.isSpinner}"
                                      title="Place Order"
                                      onclick="{!c.placeOrder}" class="buttonClass"/>
                </aura:set>
            </lightning:card>                
            <lightning:accordion  allowMultipleSectionsOpen="true"  activeSectionName="Shopping Cart" >
                <lightning:accordionSection name="Shopping Cart" label="Shopping Cart">
                    <div class="showScroll">
                        <ui:scrollerWrapper class="scrollerSizecart">
                            <aura:if isTrue="{!!v.isMobile}">
                                <table class="slds-table slds-table_cell-buffer slds-table_fixed-layout slds-table_bordered" >
                                    <thead >
                                        <tr>
                                            <th class="slds-truncate"><b>Photo</b></th>
                                            <th  style="white-space:pre-wrap;"><b>Item Description</b></th>
                                            <th style="white-space:pre-wrap;" class="slds-text-align_center"><b> Max Qty</b></th>
                                            <th class="slds-truncate"><b>Qty</b></th>
                                            <th class="slds-truncate slds-text-align_center"><b>Delete</b></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <aura:iteration items="{!v.MaterialItemsInCart}" var="item"  indexVar="rowIndex">
                                            <tr>
                                                <td class="slds-truncate" ><img src="{!v.prefixURL + item.value.ContentVersionId}" width="200" height="30" alt="No Image"/></td>
                                                
                                                <td style="white-space:pre-wrap;"  >
                                                    <b>{!item.value.MI.Name}</b><br/>                                        
                                                    <b>Package Type:</b> {!item.value.MI.Package_Type__c}
                                                </td>
                                                <td class="slds-truncate slds-text-align_center" id="{!rowIndex+'maxQty'}">
                                                    {!item.value.MI.Max_Qty__c}
                                                </td>
                                                <td>
                                                    <div id="{!rowIndex+'qty'}" >
                                                        <ui:inputText value="{!item.value.quantity}" class="slds-input inputstyle" labelClass="{!rowIndex}" updateOn="change" change="{!c.checkQuantity}" maxlength="2"/>
                                                    </div>
                                                    <b class="slds-wrap" wdith="25%;" id="{!rowIndex+'erMsg'}" style="display:none;">The Quantity must be less than Max Quantity of Material Item</b>
                                                </td>
                                                <td class="slds-text-align_center">
                                                    <a  onclick="{!c.RemoveFromCartSection}" data-value="{!rowIndex}">
                                                        <lightning:icon  iconName="utility:delete" class="slds-icon slds-icon_small" size="small" alternativeText="Remove"/>
                                                        <span class="slds-assistive-text">Delete Icon</span>
                                                    </a>
                                                </td>
                                            </tr>
                                        </aura:iteration>
                                    </tbody>
                                </table>
                            </aura:if>
                            <aura:if isTrue="{!v.isMobile}">
                                <aura:iteration items="{!v.MaterialItemsInCart}" var="item"  indexVar="rowIndex">
                                    <table>
                                        <tr>
                                            <td  width="60%">
                                                <img src="{!v.prefixURL + item.value.ContentVersionId}" width="150" height="30" alt="No Image"/>
                                                <br/>      
                                                <b><p style="">{!item.value.MI.Name}</p></b>                                    
                                                <b>Package Type:</b> {!item.value.MI.Package_Type__c}
                                                <tr><td width="40%" ><b>Max Qty:</b></td>
                                                    <td width="60%" ><p id="{!rowIndex+'maxQty'}">
                                                        {!item.value.MI.Max_Qty__c}
                                                        </p></td>
                                                </tr>
                                            </td>
                                            <td  style="padding-left: 30px;">
                                                <p>
                                                    <div id="{!rowIndex+'qty'}">
                                                        Qty:<br/> <ui:inputText  value="{!item.value.quantity}" class="inputstyle slds-input" labelClass="{!rowIndex}" updateOn="change" change="{!c.checkQuantity}" maxlength="2"/>
                                                    </div>
                                                    <b class="slds-wrap"  id="{!rowIndex+'erMsg'}" style="display:none;">The Quantity must be less than Max Quantity of Material Item</b>
                                                </p>
                                                <lightning:button name="{!rowIndex}" class="btninput" variant="destructive" label="Remove" title="Destructive action" onclick="{! c.RemoveFromCartSection }"/>
                                                <!--a  onclick="{!c.RemoveFromCartSection}" data-value="{!rowIndex}">
                                                        <lightning:icon  iconName="utility:delete" class="slds-icon slds-icon_small" size="small" alternativeText="Remove"/>
                                                        <span class="slds-assistive-text">Delete Icon</span>
                                                    </a-->  
                                            </td>
                                        </tr>
                                    </table>
                                    <hr style="display: block;margin: 1rem 0 1rem 0;border-top: 1px solid rgb(221, 219, 218);"/>
                                </aura:iteration>
                            </aura:if>
                        </ui:scrollerWrapper>
                        <lightning:card>
                            <aura:set attribute = "actions">
                                <lightning:button variant="neutral"
                                                  label="Continue Shopping"
                                                  disabled="{!v.isSpinner}"
                                                  title="Continue Shopping"
                                                  onclick="{!c.continueShopping}" class="buttonClass"/>
                                
                                <lightning:button variant="neutral"
                                                  label="Cancel Order"
                                                  title="Cancel Order"
                                                  disabled="{!v.isSpinner}"
                                                  onclick="{!c.cancelorder}" class="buttonClass"/>
                                
                                <lightning:button variant="brand"
                                                  label="Place Order"
                                                  disabled="{!v.isSpinner}"
                                                  title="Place Order"
                                                  onclick="{!c.placeOrder}" class="buttonClass"/>
                                
                            </aura:set>
                        </lightning:card>
                    </div>
                </lightning:accordionSection>
            </lightning:accordion>
            
            <!--**********************************************End of ViewCartSection****************************-->
        </aura:if>
        <br/>
        <br/>
        <br/>
        <aura:if isTrue="{!v.cancelitems}">
            
            <div class="slds-modal__content slds-p-around--x-small slds-align_absolute-center slds-size_1-of-1 slds-is-relative">
                <form class="slds-form--stacked">
                    <b>To cancel this order and empty your cart click "Continue" or go "Back to Cart"</b> 
                </form> <br/>
            </div>
            <!--End of Modal Body--> 
            <!--Modal Footer-->  
            <div class="modal-footer slds-modal__footer slds-size_1-of-1"> 
                <lightning:button variant="brand" label="Continue" title="Continue" onclick="{!c.backTohomepage}"/>
                <lightning:button variant="Neutral" class="slds-button" label="Back" onclick="{!c.backToexistedpage}"/>
            </div>
            
        </aura:if>
        
        <aura:if isTrue="{!v.cancelplaceditems}">
            
            <div class="slds-modal__content slds-p-around--x-small slds-align_absolute-center slds-size_1-of-1 slds-is-relative">
                <form class="slds-form--stacked">
                    <b>To cancel this order and empty your cart click "Continue" or go "Back to Cart"</b> 
                </form> <br/>
            </div>
            <!--End of Modal Body--> 
            <!--Modal Footer-->  
            <div class="modal-footer slds-modal__footer slds-size_1-of-1"> 
                <lightning:button variant="brand" label="Continue" title="Continue" onclick="{!c.continuebackToStoreFrontforplaceorder}"/>
                <lightning:button variant="Neutral" class="slds-button" label="Back" onclick="{!c.backToexistedcartpage}"/>
            </div>
            
        </aura:if>
        
        
    </lightning:card>
    
</aura:component>