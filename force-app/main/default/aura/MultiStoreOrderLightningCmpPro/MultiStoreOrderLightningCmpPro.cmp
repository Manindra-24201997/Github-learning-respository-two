<aura:component controller='MultiStoreOrderLigtningCmpCtrlPro' implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <!-- create 2 aura handler with waiting and donewaiting events-->
    <aura:handler event="aura:waiting" action="{!c.showSpinner}"/>
    <aura:handler event="aura:doneWaiting" action="{!c.hideSpinner}"/>
    <!--create a component attributs -->
    <aura:attribute name="Loading" type="boolean" default="false"/>
    
    <aura:attribute name="storeColumns" type="list" />
    <aura:attribute name="CWrap" type="object" />
    <!--aura:attribute name="storeSuppliesColumns" type="list" /-->
    <!--aura:attribute name="storeSuppliesData" type="object" /-->
    <aura:attribute name="selectedStoresList" type="list"/>  
    <aura:attribute name="MaterialType" type="object" default='Manindra'/>
    <aura:attribute name="MaterialItems" type="object"/>  
    <aura:attribute name="MaterialItemsInCart" type="object"/>
    <aura:attribute name="combineStoreWrapper" type="object"/>
    <aura:attribute name="clientStoreList" type="list"/>
    <aura:attribute name="cartItemIdList" type="list"/>
    <aura:attribute name="prefixURL" type="String" default="/sfc/servlet.shepherd/version/download/"/>
    <aura:attribute name="slectedPickListValue" type="string" />
    <aura:attribute name="enteredInputSearch" type="string" />
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="ShowCombineList" type="boolean" default="false"/>
    <aura:attribute name="ShowAddCartSection" type="boolean" default="false"/>
    <aura:attribute name="ShowStoreSupplies" type="boolean" default="false"/>
    <aura:attribute name="ShowStoreList" type="boolean" default="true"/>  
    <aura:attribute name="boolval" type="boolean" default="false" />
    <aura:attribute name="showstorebackbutton" type="boolean" default="true" />
    <aura:attribute name="carthold" type="boolean" default="false" />
    <aura:attribute name="cancelitems" type="boolean" default="false" />
    <aura:attribute name="isSpinner" type="boolean" default="false"/>
    <aura:attribute name="stockLables" type="list" />
    
    <aura:attribute name="StoredMaterialItems" type="object"/>    
    <aura:attribute name="cartitemids" type="list"/>
    
    <aura:if isTrue="{!v.Loading}">
        <div aura:id="spinnerId" class="slds-spinner_container">
            <div class="slds-spinner--brand  slds-spinner slds-spinner--large slds-is-relative" role="alert">
                <span class="slds-assistive-text">Loading</span>
                <div class="slds-spinner__dot-a"></div>
                <div class="slds-spinner__dot-b"></div>
            </div>
        </div>
    </aura:if>
    <!--===========================================*Store List Layout*======================================-->
    
    <lightning:card  title="" >
        <aura:if isTrue="{!v.ShowStoreList}">
            <div class="showScroll">
                <ui:scrollerWrapper class="scrollerSize">  
                    <lightning:card>
                        <aura:set attribute="title">                
                            <img src="{!$Resource.LovesHeaderLogo}" width="250" height="250"/>                        
                        </aura:set>  
                        <aura:set attribute="actions">
                            <lightning:button class="buttonClass"
                                              variant="neutral"
                                              label="Back"
                                              title="Back"
                                              onclick="{!c.backToStoreFront}"/>
                            <lightning:button class="buttonClass"
                                              variant="brand"
                                              label="Next"
                                              title="Next"
                                              onclick="{!c.ShowStoreSuppliesLayout}" />
                        </aura:set>
                    </lightning:card>
                    
                    <lightning:accordion  allowMultipleSectionsOpen="true"  activeSectionName="MultiStore" >
                        
                        <lightning:accordionSection name="MultiStore" label="Store List">
                            <b>  Please note that these items require 2-3 weeks for production.</b>
                            
                            <!--lightning:datatable aura:id="storetable"
                                 keyField="Id"
                                 columns="{!v.storeColumns}"
                                 data="{!v.storeData}"                                
                                 onrowselection="{!c.handleRow}"
                                 /-->
                            
                            <table class="slds-table slds-table_cell-buffer slds-table_bordered" style="margin-top:15px;">
                                <thead >
                                    <tr>
                                        <th class="slds-truncate "><b>Action</b></th>
                                        <th  class="slds-truncate" width="70%"><b>Name</b></th>
                                        <th  class="slds-truncate" style="white-space:pre-wrap;"><b>Client Code</b></th>  
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!v.CWrap}" var="item">
                                        <tr>
                                            <td class="">
                                                <div class="slds-checkbox">
                                                    <label class="slds-checkbox">
                                                        <ui:inputCheckbox value="{!item.varCSelect}" change="{!c.onCheck}"/>
                                                        <span class="slds-checkbox--faux" />                                
                                                    </label>
                                                </div>
                                            </td>
                                            <td style="word-wrap:break-word;white-space:pre-wrap" class="slds-truncate">
                                                {!item.varClient.Name}
                                            </td>
                                            <td style="word-wrap:break-word;" class="slds-truncate">
                                                {!item.varClient.Client_Code__c}
                                            </td>
                                        </tr>
                                    </aura:iteration>
                                </tbody>
                            </table>
                            
                        </lightning:accordionSection>
                    </lightning:accordion>
                </ui:scrollerWrapper>
            </div>
        </aura:if>
        
        <!-- The below if is new logic -->
        <aura:if isTrue = "{!v.boolval}">
            <div class="showScroll">
                <ui:scrollerWrapper class="scrollerSize">
                    <lightning:card>
                        <aura:set attribute="title">
                            <aura:if isTrue="{!!v.isMobile}">
                                <img src="{!$Resource.LovesHeaderLogo}" width="250" height="250"/>
                            </aura:if>
                        </aura:set>  
                        <aura:set attribute="actions">
                            
                            <lightning:button variant="neutral"
                                              label="Back"
                                              title="Back"
                                              onclick="{!c.backToStores}"
                                              disabled="{!v.MaterialItemsInCart.length>0}"
                                              class="buttonClass"/>  <lightning:button label="Go To Cart" title="Go To Cart" class="buttonClass" onclick="{!c.goToCart}"/>
                            
                            
                        </aura:set>
                    </lightning:card>
                    <lightning:accordion  allowMultipleSectionsOpen="true"  activeSectionName="Select Item Category" >
                        <lightning:accordionSection name="Select Item Category" label="Select Item Category">
                            <aura:if isTrue="{!empty(v.MaterialItems)}">
                                <!--  <div class="keyInput">
                                    <lightning:select aura:id="MaterialItemCategory" name="MaterialTypeSelect" label="Select Item Category" class="" onchange="{!c.onMiSelect}">
                                        <option  value="">All Categories</option>            
                                        <aura:iteration items="{!v.MaterialType}" var="item">
                                            <option value="{!item}">{!item}</option>
                                        </aura:iteration>
                                    </lightning:select>
                                </div>
                                <br/> <br/>-->
                                <div class="slds-grid slds-gutters slds-wrap" style="margin-top: 45px;margin-left:40px;">
                                    <aura:iteration items="{!v.MaterialType}" var="items" indexVar="idx">
                                        <div class="slds-col slds-size_2-of-12" >
                                            <br/>
                                            <aura:if isTrue="{!items == 'Banners'}">
                                                <img src="{!$Resource.Banners}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style="margin-left:20px;white-space:nowrap;align:center;" id="{!idx}"> Banners</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Cigarette POP Materials'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Cigarette POP Materials </label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'CMN'}" >
                                                <img src="{!$Resource.CMNPromo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 30px;white-space: nowrap;align:center;" id="{!idx}">CMN</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'CNG'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">CNG</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Coffee'}" >
                                                <img src="{!$Resource.Coffee}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 25px;white-space: nowrap;align:center;" id="{!idx}">Coffee</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Cooler'}" >
                                                <img src="{!$Resource.Cooler}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 24px;white-space: nowrap;align:center;" id="{!idx}">Cooler</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Customer Commitments'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Customer Commitments</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Decals'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Decals</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Deli'}" >
                                                <img src="{!$Resource.Deli}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 34px;white-space: nowrap;align:center;" id="{!idx}">Deli</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Diesel Desk'}" >
                                                <img src="{!$Resource.DieselGasDesk}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 9px;white-space: nowrap;align:center;" id="{!idx}">Diesel Desk</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Facilities'}" >
                                                <img src="{!$Resource.Facilities}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 13px;white-space: nowrap;align:center;" id="{!idx}">Facilities</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Finished Goods'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Finished Goods</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Forms'}" >
                                                <img src="{!$Resource.Forms}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 28px;white-space: nowrap;align:center;" id="{!idx}">Forms</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Fountain'}" >
                                                <img src="{!$Resource.Fountain}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 21px;white-space: nowrap;align:center;" id="{!idx}">Fountain</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Fuel Pumps'}" >
                                                <img src="{!$Resource.FuelPump}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 5px;white-space: nowrap;align:center;" id="{!idx}">Fuel Pumps</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Gas Desk'}" >
                                                <img src="{!$Resource.DieselGasDesk}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 13px;white-space: nowrap;align:center;" id="{!idx}">Gas Desk</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Literature'}" >
                                                <img src="{!$Resource.Literature}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 15px;white-space: nowrap;align:center;" id="{!idx}">Literature</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Loss Prevention'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Loss Prevention</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Loyalty'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Loyalty</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Laundry'}" >
                                                <img src="{!$Resource.Laundry}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Laundry</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Merchandising'}" >
                                                <img src="{!$Resource.Merchandising}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left:-3px;white-space: nowrap;align:center;" id="{!idx}">Merchandising</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Office'}" >
                                                <img src="{!$Resource.office}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 20px;white-space: nowrap;align:center;" id="{!idx}">Office</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Shelf Communication'}" >
                                                <img src="{!$Resource.ShelfCommunication}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left:-50px;white-space: nowrap;align:center;" id="{!idx}">Shelf Communication</label><br/><br/>
                                            </aura:if>
                                            
                                            
                                            
                                            <aura:if isTrue="{!items == 'Other Signs'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Other Signs</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Posters'}" >
                                                <img src="{!$Resource.Posters}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Posters</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Propane'}" >
                                                <img src="{!$Resource.Propane}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 21px;white-space: nowrap;align:center;" id="{!idx}">Propane</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Pump Toppers'}" >
                                                <img src="{!$Resource.PumpTopper}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: -3px;white-space: nowrap;align:center;" id="{!idx}">Pump Toppers</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Recruiting'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Recruiting</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Restaurant'}" >
                                                <img src="{!$Resource.Restaurant}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 10px;white-space: nowrap;align:center;" id="{!idx}">Restaurant</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Roller Grill'}" >
                                                <img src="{!$Resource.RollerGrill}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 10px;white-space: nowrap;align:center;" id="{!idx}">Roller Grill</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Restrooms'}" >
                                                <img src="{!$Resource.Restroom}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 10px;white-space: nowrap;align:center;" id="{!idx}">Restrooms</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Safety'}" >
                                                <img src="{!$Resource.Safety}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 27px;white-space: nowrap;align:center;" id="{!idx}">Safety</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Showers'}" >
                                                <img src="{!$Resource.Showers}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 20px;white-space: nowrap;align:center;" id="{!idx}">Showers</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'SNAP'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">SNAP</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Speedco'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Speedco</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'TirePass'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">TirePass</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Trillium CNG'}" >
                                                <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 23px;white-space: nowrap;align:center;" id="{!idx}">Trillium CNG</label><br/><br/>
                                            </aura:if>
                                            
                                            <aura:if isTrue="{!items == 'Truck Care'}" >
                                                <img src="{!$Resource.TruckCare}" onclick="{!c.onMiSelect}" id="{!items}" class= "fitimage"/><br/>
                                                <label class="slds-form-element__label"  style=" margin-left: 13px;white-space: nowrap;align:center;" id="{!idx}">Truck Care</label><br/><br/>
                                            </aura:if>
                                            
                                        </div>
                                    </aura:iteration>
                                </div>
                            </aura:if>
                        </lightning:accordionSection>
                    </lightning:accordion>
                </ui:scrollerWrapper>
            </div>
        </aura:if>
        <!-- Ends Here -->
        
        <!-- New Logic added on 19 - 08 - 2022 for back functionality and cart holding -->
        <aura:if isTrue = "{!v.carthold}">
            <div class="showScroll">
                <ui:scrollerWrapper class="scrollerSize">
                    <lightning:card>
                        <aura:set attribute="title">
                            <aura:if isTrue="{!!v.isMobile}">
                                <img src="{!$Resource.LovesHeaderLogo}" width="250" height="250"/>
                            </aura:if>
                        </aura:set>  
                        <aura:set attribute="actions">
                            
                            <lightning:button variant="neutral"
                                              label="Back"
                                              title="Back"
                                              onclick="{!c.backToStores}"
                                              disabled="{!v.MaterialItemsInCart.length>0}"
                                              class="buttonClass"/>
                            
                            <!--  <aura:if isTrue="{!v.MaterialItemsInCart.length>0}">  </aura:if>-->
                            <lightning:button label="Go To Cart" title="Go To Cart" class="buttonClass" onclick="{!c.goToCart}"/>
                            
                            
                        </aura:set>
                    </lightning:card>
                    <lightning:accordion  allowMultipleSectionsOpen="true"  activeSectionName="Select Item Category" >
                        <lightning:accordionSection name="Select Item Category" label="Select Item Category">
                            <!-- The below is for cart hold -->
                            <!-- <div class="keyInput">
                                <lightning:select aura:id="MaterialItemCategorycarthold" name="MaterialTypeSelect" label="Select Item Category" class="" onchange="{!c.onMiSelectCarthold}">
                                    <option  value="">All Categories</option>            
                                    <aura:iteration items="{!v.MaterialType}" var="item">
                                        <option value="{!item}">{!item}</option>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                            <br/> <br/>-->
                            <div class="slds-grid slds-gutters slds-wrap" style="margin-top: 45px;">
                                <aura:iteration items="{!v.MaterialType}" var="items" indexVar="idx">
                                    <div class="slds-col slds-size_2-of-12" >
                                        <br/>
                                        <aura:if isTrue="{!items == 'Banners'}">
                                            <img src="{!$Resource.Banners}" onclick="{!c.onMiSelectCarthold}" id="{!items}"  class= "fitimage"/><br/>
                                            <label class="slds-form-element__label"  style=" margin-left: 20px;white-space:nowrap;align:center;" id="{!idx}"> Banners</label><br/><br/>
                                        </aura:if>
                                        
                                        <aura:if isTrue="{!items == 'Cigarette POP Materials'}" >
                                            <img src="{!$Resource.JS_Logo}" onclick="{!c.onMiSelectCarthold}" id="{!items}" class= "fitimage"/><br/>
