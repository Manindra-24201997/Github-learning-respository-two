<aura:component controller="MapOfBBForClient" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    
    <aura:attribute name="clientId" type="String"/>  
    <!-- handlers-->
    <aura:handler name="init" value="{!this}" action="{!c.doinit}"/>
    <aura:attribute name="ClientMapSec" type="String" default="Map" required="true" access="global"/>
    <aura:if isTrue="{!v.clientId}">
        <lightning:card title="">
            <iframe src="{! 'https://loves-storefront--lcsandbox.lightning.force.com/apex/DisplayBillboardForClientContact?Id=' + v.clientId }" width="100%" height="500px;" frameBorder="0"/>
        </lightning:card>
              
    </aura:if>
</aura:component>