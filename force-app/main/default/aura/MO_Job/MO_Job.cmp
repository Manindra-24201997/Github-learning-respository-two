<aura:component controller="MO_JobClass" implements="flexipage:availableForAllPageTypes,force:lightningQuickActionWithoutHeader,lightning:actionOverride,force:hasRecordId,flexipage:availableForRecordHome" access="global" >
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isAccess" type="list" /><!-- to check  permissions(creatable,editable)-->
    <aura:attribute name="ObjectType" type="Object"/> 
    <aura:attribute name="isMPLIOpen" type="boolean" default="false"/>
    <aura:attribute name="MPLIRecordid" type="String" />
    <aura:attribute name="CalcUnitval" type="String" default = "Each"/>
    <aura:attribute name="MPONameVendorName" type="String[]" default='[]'/>
    <aura:attribute name="MItem_Records" type="Object"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <aura:if isTrue="{!v.isMPLIOpen}">
        <lightning:recordEditForm aura:id="recordEditForm" density="comfy" objectApiName="Material_Purchase_Line_Item__c" recordId="{!v.MPLIRecordid}" onload="{!c.MPLIload}" onsubmit="{!c.MPLIOnsubmit}"  onsuccess="{!c.onMPLIRecordSuccess}"  >
            <lightning:messages />
            <div aura:id="editDialog" role="dialog" tabindex="-1" aria-labelledby="header43" class="slds-modal slds-fade-in-open">
                <div aura:id="errorMsgs"></div>
                <div class="slds-modal__container">
                    <div class="slds-modal__header">
                        <h2 class="slds-text-heading--medium">
                            New Material Order Line Item
                        </h2>
                    </div>
                    <div class="slds-modal__content slds-p-around--medium slds-grid slds-wrap ">
                        
                        <lightning:layout multipleRows="true">
                            <aura:iteration items="{!v.fieldset}" var="field">
                                
                                <aura:if isTrue="{!field == 'Calc_Unit__c' || field == 'Material_Item__c' || field == 'Material_Order__c' || field == 'MPLI_Status__c'}">
                                    <aura:set attribute="else">
                                        <lightning:inputField fieldName="{!field}" aura:id="MPLIQty"  class="{!'slds-form-element slds-size--1-of-2 slds-p-horizontal_x-small' + ' ' +((field=='Qty__c') ? 'frequired' :' ')}"  />
                                    </aura:set>
                                </aura:if>
                                
                                <aura:if isTrue="{!field == 'Material_Order__c'}">
                                    <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-form-element  slds-p-horizontal_x-small" >
                                            <label class="slds-form-element__label" for="text-input-id-1">
                                                {!v.ObjectType.Material_Purchase_Line_Item__c.Material_Order__c.label}
                                            </label>
                                            <div class="slds-form-element__control">
                                                <ui:outputText value="{!v.MPONameVendorName[0]}"/>
                                            </div>
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if>
                                
                                <aura:if isTrue="{!field=='Material_Item__c'}">
                                    <div class="slds-size--1-of-2 slds-p-horizontal_x-small">
                                        <lightning:select  name="MaterialItemSelect" aura:id="MISelectId"  label="{!v.ObjectType.Material_Purchase_Line_Item__c.Material_Item__c.label}"  class="frequired">
                                            <option text="--None--" value="" />
                                            <aura:iteration items="{!v.MItem_Records}" var="mi">
                                                <option text="{!mi.Name}" value="{!mi.Id}" />
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </aura:if>
                                
                                <aura:if isTrue="{!field=='Calc_Unit__c'}">
                                    <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-form-element  slds-p-horizontal_x-small" >
                                            <label class="slds-form-element__label" for="text-input-id-1">
                                                {!v.ObjectType.Material_Purchase_Line_Item__c.Calc_Unit__c.label}
                                            </label>
                                            <div class="slds-form-element__control">
                                                <ui:outputText value="{!v.CalcUnitval}"/>
                                            </div>
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if>
                            </aura:iteration>
                            <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                <div class="slds-form-element  slds-p-horizontal_x-small" >
                                    <label class="slds-form-element__label" for="text-input-id-1">
                                        Vendor Name
                                    </label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.MPONameVendorName[1]}"/>
                                    </div>
                                </div>
                            </lightning:layoutItem>
                            <div class="slds-form-element slds-size--3-of-6 slds-p-horizontal_x-small frequired">
                                <lightning:input type="number" name="Receipt Qty" aura:id="receiptval" label="Receipt Qty" />
                            </div>
                        </lightning:layout>
                        <br></br>
                    </div>
                    <div class="slds-modal__footer">                
                        <lightning:button variant="neutral" label="Cancel" onclick="{!c.closeModel}" />
                        <lightning:button  variant="brand"  label="Save" type="submit" />
                    </div>              
                </div>
            </div>
        </lightning:recordEditForm>
    </aura:if>
    
    
</aura:component>